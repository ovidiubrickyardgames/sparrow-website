---
import 'intl-tel-input/dist/css/intlTelInput.css';

const {
  label = Astro.currentLocale === 'fr' ? 'Numéro de téléphone' : 'Phone Number',
  id,
  required = false,
} = Astro.props;

interface Props {
  label?: string;
  id: string;
  required?: boolean;
}
---

<div class="phone-input-container">
  <label for={id} class="sr-only">{label}</label>
  <input
    type="tel"
    name="hs-phone-number"
    id={id}
    required={required}
    class="dark:text-brand-text/90 block w-full rounded-lg border border-neutral-200 bg-neutral-50 px-4 py-3 text-sm text-neutral-800 placeholder:text-neutral-500 focus:border-neutral-200 focus:ring-3 focus:ring-neutral-400 focus:outline-hidden disabled:pointer-events-none disabled:opacity-50 dark:border-neutral-600 dark:bg-neutral-700/30 dark:placeholder:text-neutral-400 dark:focus:ring-1"
    placeholder={label}
  />
</div>

<style is:global>
  .iti {
    width: 100%;
    display: block;
  }
  .iti__country-list {
    background-color: #fafafa !important;
    border: 1px solid #e5e5e5 !important;
    border-radius: 0.5rem !important;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1) !important;
    z-index: 50 !important;
    color: #1f2937 !important;
  }
  .dark .iti__country-list {
    background-color: #1f2937 !important;
    border-color: #374151 !important;
    color: #f9fafb !important;
  }
  .iti__country {
    padding: 10px 15px !important;
  }
  .iti__country:hover {
    background-color: #f3f4f6 !important;
  }
  .dark .iti__country:hover {
    background-color: #374151 !important;
  }
  .iti__selected-country {
    border-top-left-radius: 0.5rem !important;
    border-bottom-left-radius: 0.5rem !important;
    padding-left: 12px !important;
    background: transparent !important;
  }
  .iti__selected-dial-code {
    color: #1f2937 !important;
    margin-left: 4px !important;
  }
  .dark .iti__selected-dial-code {
    color: #f9fafb !important;
  }
  .iti__arrow {
    border-top-color: #6b7280 !important;
  }
  .dark .iti__arrow {
    border-top-color: #9ca3af !important;
  }
  .iti__arrow--up {
    border-bottom-color: #6b7280 !important;
  }
  .dark .iti__arrow--up {
    border-bottom-color: #9ca3af !important;
  }
  /* Fix for input padding when ITI is active */
  /* When separateDialCode is true, the padding needs to be dynamic or larger */
  .iti input {
    padding-left: 100px !important;
  }
</style>
