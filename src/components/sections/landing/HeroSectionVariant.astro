<style>
  .hero-section-wrapper {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .perspective-1000 {
    perspective: 1200px;
  }
  
  .rotate-y-\[-4deg\] {
    transform: rotateY(-4deg);
  }
  
  .rotate-x-\[2deg\] {
    transform: rotateX(2deg);
  }

  /* Animations for dashboard visual */
  .dashboard-window {
    animation: float 10s ease-in-out infinite;
  }

  .chart-bar {
    animation: growBar 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    transform-origin: bottom;
    transform: scaleY(0);
  }

  .chart-bar:nth-child(2) { animation-delay: 0.05s; }
  .chart-bar:nth-child(3) { animation-delay: 0.1s; }
  .chart-bar:nth-child(4) { animation-delay: 0.15s; }
  .chart-bar:nth-child(5) { animation-delay: 0.2s; }
  .chart-bar:nth-child(6) { animation-delay: 0.25s; }
  .chart-bar:nth-child(7) { animation-delay: 0.3s; }
  .chart-bar:nth-child(8) { animation-delay: 0.35s; }

  .progress-bar-1 {
    animation: fillProgress1 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    width: 0;
  }

  .floating-card-1 {
    animation: floatCard1 8s ease-in-out infinite;
  }

  .floating-card-2 {
    animation: floatCard2 9s ease-in-out infinite;
    animation-delay: 1.5s;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotateY(-4deg) rotateX(2deg);
    }
    50% {
      transform: translateY(-12px) rotateY(-1deg) rotateX(5deg);
    }
  }

  @keyframes growBar {
    0% {
      transform: scaleY(0);
      opacity: 0;
    }
    100% {
      transform: scaleY(1);
      opacity: 1;
    }
  }

  @keyframes fillProgress1 {
    0% { width: 0; }
    100% { width: 85%; }
  }

  @keyframes floatCard1 {
    0%, 100% {
      transform: translateY(0) translateX(0);
    }
    50% {
      transform: translateY(-15px) translateX(8px);
    }
  }

  @keyframes floatCard2 {
    0%, 100% {
      transform: translateY(0) translateX(0);
    }
    50% {
      transform: translateY(12px) translateX(-10px);
    }
  }
</style>

<script>
  function initHeroCanvas() {
    const canvas = document.getElementById("c") as HTMLCanvasElement | null;
    const ctx = canvas?.getContext("2d");
    const wrap = document.getElementById("hero-wrap");

    if (!canvas || !ctx || !wrap) return;

    if ((canvas as any)._isAnimating) return;
    (canvas as any)._isAnimating = true;

    let W: number = 0, H: number = 0;
    let t = 0;
    let animationFrameId: number;

    function resize() {
      if (!wrap || !canvas || !ctx) return;
      W = wrap.offsetWidth;
      H = wrap.offsetHeight;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      ctx.scale(dpr, dpr);
    }
    
    const ro = new ResizeObserver(() => resize());
    ro.observe(wrap);
    resize();

    function noise(x: number, y: number, t: number) {
      const v1 =
        Math.sin(x * 0.008 + t * 0.18) * Math.cos(y * 0.009 - t * 0.12);
      const v2 = Math.sin(x * 0.014 - y * 0.007 + t * 0.09);
      const v3 = Math.cos(x * 0.006 + y * 0.011 - t * 0.15) * 0.5;
      const v4 = Math.sin((x + y) * 0.005 + t * 0.07) * 0.3;
      return (v1 + v2 + v3 + v4) / 2.3;
    }

    function getIsoLines(levels: number[]) {
      const step = 6;
      const cols = Math.ceil(W / step) + 1;
      const rows = Math.ceil(H / step) + 1;

      const grid: number[][] = [];
      for (let r = 0; r < rows; r++) {
        grid[r] = [];
        for (let c = 0; c < cols; c++) {
          grid[r][c] = noise(c * step, r * step, t);
        }
      }

      const lines: Record<number, number[][][]> = {};
      levels.forEach((lv) => (lines[lv] = []));

      for (let r = 0; r < rows - 1; r++) {
        for (let c = 0; c < cols - 1; c++) {
          const x0 = c * step,
            y0 = r * step;
          const tl = grid[r][c],
            tr = grid[r][c + 1];
          const bl = grid[r + 1][c],
            br = grid[r + 1][c + 1];

          levels.forEach((lv) => {
            const pts: number[][] = [];

            function interp(
              ax: number,
              ay: number,
              av: number,
              bx: number,
              by: number,
              bv: number,
            ) {
              if (av < lv === bv < lv) return;
              const s = (lv - av) / (bv - av);
              pts.push([ax + (bx - ax) * s, ay + (by - ay) * s]);
            }

            interp(x0, y0, tl, x0 + step, y0, tr);
            interp(x0 + step, y0, tr, x0 + step, y0 + step, br);
            interp(x0, y0 + step, bl, x0 + step, y0 + step, br);
            interp(x0, y0, tl, x0, y0 + step, bl);

            if (pts.length === 2) {
              lines[lv].push(pts);
            }
          });
        }
      }

      return lines;
    }

    function draw() {
      t += 0.012;
      ctx!.clearRect(0, 0, W, H);

      const levelCount = 22;
      const levels: number[] = [];
      for (let i = 0; i < levelCount; i++) {
        levels.push(-1.05 + (i / (levelCount - 1)) * 2.1);
      }

      const isoLines = getIsoLines(levels);

      levels.forEach((lv, idx) => {
        const segs = isoLines[lv];
        if (!segs || !segs.length) return;

        const t_norm = idx / (levelCount - 1);
        const isMid = t_norm > 0.3 && t_norm < 0.7;

        // Restore original low opacity values
        const baseAlpha = isMid ? 0.10 : 0.06;

        const r = 0;
        const g = 0;
        const b = 0;

        ctx!.strokeStyle = `rgba(${r},${g},${b},${baseAlpha})`;
        ctx!.lineWidth = isMid ? 1.2 : 0.8;
        ctx!.lineCap = "round";
        ctx!.lineJoin = "round";

        segs.forEach(([p1, p2]) => {
          ctx!.beginPath();
          ctx!.moveTo(p1[0], p1[1]);
          ctx!.lineTo(p2[0], p2[1]);
          ctx!.stroke();
        });
      });

      animationFrameId = requestAnimationFrame(draw);
    }

    draw();

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationFrameId);
      ro.disconnect();
      if (canvas) (canvas as any)._isAnimating = false;
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initHeroCanvas);
  initHeroCanvas();
</script>
