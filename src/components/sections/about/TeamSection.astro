---
import { useTranslations } from '@/copywriting';
import Icon from '@components/ui/icons/Icon.astro';

const pathParts = Astro.url.pathname.split('/');
const currentLocale = ['fr', 'ro', 'de'].includes(pathParts[1])
  ? pathParts[1]
  : Astro.currentLocale || 'en';
const copy = useTranslations(currentLocale);
const teamCopy = copy.pages.about.team;

const teamMembers = [
  {
    name: 'Cotia Cosmin',
    role: teamCopy.members.cosmin.role,
    image: 'https://www.brainsymphony.tech/_astro/Cosmin.LS7PqyKL.jpg',
    linkedin: 'https://www.linkedin.com/in/cosmin-cotia-740455108/',
    bio: teamCopy.members.cosmin.bio,
  },
  {
    name: 'Ovidiu Tulbure',
    role: teamCopy.members.ovidiu.role,
    image: 'https://www.brainsymphony.tech/_astro/Ovidiu.8quafmWC.jpg',
    linkedin: 'https://www.linkedin.com/in/ovidiu-tulbure-45bb61178/',
    bio: teamCopy.members.ovidiu.bio,
  },
];

const { title, subTitle } = Astro.props;

interface Props {
  title: string;
  subTitle: string;
}
---

<section class="content-container py-16 lg:py-24">
  <div class="mx-auto mb-16 max-w-2xl text-center">
    <h2
      class="text-brand-text dark:text-brand-text/90 text-3xl font-bold tracking-tight sm:text-4xl"
    >
      {title}
    </h2>
    <p class="text-brand-text/70 dark:text-brand-text/60 mt-4 text-lg">
      {subTitle}
    </p>
  </div>

  <div class="flex flex-wrap justify-center gap-x-12 gap-y-16">
    {
      teamMembers.map(member => (
        <div class="group relative w-full max-w-sm">
          <div class="bg-brand-accent-1/5 group-hover:shadow-brand-accent-1/20 relative aspect-square overflow-hidden rounded-2xl transition-all duration-500 group-hover:scale-[1.02] group-hover:shadow-2xl">
            <img
              src={member.image}
              alt={member.name}
              class="h-full w-full object-cover grayscale transition duration-500 group-hover:grayscale-0"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-linear-to-t from-[#ffffff]/80 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />

            <div class="absolute bottom-6 left-6 z-10 opacity-40 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100">
              <a
                href={member.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:bg-brand-accent-1 hover:text-white hover:shadow-brand-accent-1/40 flex h-12 w-12 items-center justify-center rounded-full bg-brand-primary/10 text-brand-primary shadow-lg backdrop-blur-md transition-all duration-300 hover:scale-110"
                aria-label={`${member.name} LinkedIn`}
              >
                <Icon name="linkedIn" class="h-6 w-6" />
              </a>
            </div>
          </div>
          <div class="mt-6 text-center">
            <h3 class="text-brand-text dark:text-brand-text/90 text-xl font-bold">
              {member.name}
            </h3>
            <p class="text-brand-accent-1 text-sm font-medium">{member.role}</p>
            <p class="text-brand-text/70 dark:text-brand-text/60 mt-4 text-sm leading-relaxed">
              {member.bio}
            </p>
          </div>
        </div>
      ))
    }
  </div>
</section>
