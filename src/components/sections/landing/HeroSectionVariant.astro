---
// Import the necessary dependencies
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import SecondaryCTA from "@components/ui/buttons/SecondaryCTA.astro";
import ReviewComponent from "@components/ui/blocks/ReviewComponent.astro";

// Define props from Astro
const {
  title,
  subTitle,
  primaryBtn,
  primaryBtnURL,
  secondaryBtn,
  secondaryBtnURL,
  withReview,
  avatars,
  starCount,
  rating,
  reviews,
} = Astro.props;

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
  primaryBtn?: string;
  primaryBtnURL?: string;
  secondaryBtn?: string;
  secondaryBtnURL?: string;
  withReview?: boolean;
  avatars?: Array<string>;
  starCount?: number;
  rating?: string;
  reviews?: string;
}
---

{/* Hero section */}
<div class="hero-section-wrapper relative overflow-hidden pb-24 lg:pb-0" id="hero-wrap">
  {/* Backgrounds */}
  <canvas
    id="c"
    class="absolute inset-0 w-full h-full pointer-events-none z-0"
    style="mask-image: linear-gradient(to right, transparent 0%, transparent 45%, black 75%); -webkit-mask-image: linear-gradient(to right, transparent 0%, transparent 45%, black 75%);"
  ></canvas>

  {/* Hero layout: two columns */}
  <section
    class="content-container relative z-10 flex grow flex-col justify-center pt-40 pb-8 px-4 lg:pt-32 lg:pb-32 sm:px-6 lg:px-8 w-full max-w-7xl mx-auto min-h-[92vh]"
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center w-full">
      
      {/* Left Column: Copy */}
      <div class="lg:col-span-6 flex flex-col items-start text-left z-20 lg:pl-6 xl:pl-10">
        <h1
          class="reveal-heading font-display mb-6 text-left text-5xl leading-[1.08] font-bold tracking-[-0.02em] text-zinc-950 sm:text-6xl lg:text-7xl"
        >
          <Fragment set:html={title} />
        </h1>

        {
          subTitle && (
            <p class="reveal-element mb-10 max-w-[600px] text-left text-lg leading-relaxed font-light text-[#444444] sm:text-xl">
              {subTitle}
            </p>
          )
        }

        <div class="reveal-element mt-2 flex flex-col items-start gap-4 w-full">
          <div id="hero-buttons-container" class="flex flex-col sm:flex-row gap-4 w-full">
            {
              primaryBtn && (
                <a
                  href={primaryBtnURL}
                  class="group inline-flex items-center justify-center gap-x-2 rounded-[6px] px-6 py-3.5 text-sm font-medium ring-zinc-500 transition duration-300 focus-visible:ring-3 outline-hidden bg-[#0f0f0f] hover:bg-[#1a1a1a] active:bg-black text-white 2xl:text-base w-full sm:w-fit"
                >
                  {primaryBtn}
                </a>
              )
            }
            {
              secondaryBtn && (
                <a
                  href={secondaryBtnURL}
                  class="inline-flex items-center justify-center gap-x-2 rounded-[6px] border border-zinc-200 bg-white px-6 py-3.5 text-sm font-medium text-zinc-700 shadow-sm transition-all duration-300 hover:bg-zinc-50 hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 w-full sm:w-fit 2xl:text-base"
                >
                  {secondaryBtn}
                </a>
              )
            }
          </div>
          
          <div class="flex items-center gap-2 text-zinc-500 text-[13px] font-medium mt-1">
            15-min call · no commitment
          </div>
        </div>

        {
          withReview ? (
            <div class="mt-10 sm:mt-12">
              <ReviewComponent
                avatars={avatars}
                starCount={starCount}
                rating={rating}
                reviews={reviews}
              />
            </div>
          ) : (
            ""
          )
        }
      </div>

      {/* Right Column: Premium Animated Dashboard Visual */}
      <div class="lg:col-span-6 relative z-20 w-full h-[320px] sm:h-[420px] lg:h-[480px] flex items-center justify-center perspective-1000 mt-6 lg:mt-0 px-2 sm:px-0 sm:pr-4 lg:pr-8">
        
        <div class="relative w-full h-full flex items-center justify-center origin-center">
        
          {/* Ambient Glow Behind Dashboard - Monochromatic / Emerald */}
          <div class="absolute inset-0 bg-gradient-to-tr from-zinc-200/40 via-transparent to-emerald-500/5 blur-3xl rounded-full z-0 transform-gpu scale-125"></div>

          {/* Main Dashboard Window - Completely visible within bounds */}
          <div class="dashboard-window relative z-10 w-full max-w-[580px] h-full max-h-[440px] scale-[0.90] sm:scale-100 origin-center rounded-2xl border border-zinc-200/80 bg-white/70 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] backdrop-blur-2xl overflow-hidden flex flex-col transform-gpu transition-transform duration-700 hover:rotate-y-0 rotate-y-[-4deg] rotate-x-[2deg]">
          
          {/* Header */}
          <div class="h-12 w-full border-b border-zinc-200/60 bg-zinc-50/50 flex items-center px-4 gap-3">
            <div class="flex gap-2">
              <div class="h-3 w-3 rounded-full bg-zinc-300 hover:bg-red-400 transition-colors cursor-pointer"></div>
              <div class="h-3 w-3 rounded-full bg-zinc-300 hover:bg-yellow-400 transition-colors cursor-pointer"></div>
              <div class="h-3 w-3 rounded-full bg-zinc-300 hover:bg-green-400 transition-colors cursor-pointer"></div>
            </div>
            <div class="ml-4 h-5 w-48 rounded-md bg-white border border-zinc-200/60 shadow-sm flex items-center px-2">
              <svg class="w-3 h-3 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              <div class="ml-2 text-[10px] text-zinc-400 font-medium font-sans">app.sparrow.com/outbound</div>
            </div>
          </div>

          {/* Body */}
          <div class="flex flex-1 p-4 gap-5 bg-zinc-50/30">
            {/* Sidebar */}
            <div class="w-16 sm:w-44 hidden sm:flex flex-col gap-2">
              <div class="h-8 w-full rounded-lg bg-zinc-100 border border-zinc-200/50 mb-2 flex items-center px-3 gap-2">
                <div class="h-4 w-4 rounded-sm bg-zinc-800 shrink-0"></div>
                <div class="text-[11px] font-semibold text-zinc-800">Novapath Systems</div>
              </div>
              <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-white border border-zinc-200 shadow-sm cursor-pointer relative overflow-hidden">
                 <div class="absolute left-0 top-0 bottom-0 w-1 bg-zinc-800"></div>
                 <svg class="w-4 h-4 text-zinc-800 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                 <div class="text-[11px] font-medium text-zinc-800">Command Center</div>
              </div>
              <div class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-zinc-100 transition-colors cursor-pointer">
                 <svg class="w-4 h-4 text-zinc-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                 <div class="text-[11px] font-medium text-zinc-500">Active Campaigns</div>
              </div>
              <div class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-zinc-100 transition-colors cursor-pointer">
                 <svg class="w-4 h-4 text-zinc-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                 <div class="text-[11px] font-medium text-zinc-500">Qualified Leads</div>
              </div>
              
              {/* Sidebar bottom widget */}
              <div class="mt-auto h-24 w-full rounded-xl border border-zinc-200/80 bg-white p-3 flex flex-col justify-end gap-2 shadow-sm relative overflow-hidden group">
                <div class="text-[9px] font-bold text-zinc-400 uppercase tracking-wider">Pipeline Generated</div>
                <div class="h-2 w-full rounded-full bg-zinc-100 overflow-hidden mt-1">
                  <div class="h-full w-[85%] bg-emerald-500 rounded-full progress-bar-1 shadow-sm"></div>
                </div>
                <div class="flex justify-between items-center mt-[-2px]">
                  <div class="text-[9px] text-zinc-500">Q3 Target</div>
                  <div class="text-[10px] font-bold text-zinc-800">85%</div>
                </div>
              </div>
            </div>

            {/* Main Content Area */}
            <div class="flex-1 flex flex-col gap-3 sm:gap-4">
              {/* Top Stats Row */}
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                <div class="h-20 sm:h-24 rounded-xl border border-zinc-200/80 bg-white p-3 sm:p-4 flex flex-col justify-between shadow-sm hover:shadow-md transition-shadow">
                  <div class="flex justify-between items-start">
                    <div class="text-[11px] font-semibold text-zinc-500 leading-tight">Meetings Booked</div>
                    <div class="h-6 w-6 rounded-md bg-zinc-50 flex items-center justify-center border border-zinc-100 shrink-0">
                       <svg class="w-3 h-3 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                  </div>
                  <div class="flex items-end gap-2">
                    <div class="text-2xl font-bold text-zinc-900 leading-none">42</div>
                    <div class="text-[10px] font-medium text-emerald-600 bg-emerald-50 px-1.5 py-0.5 rounded-sm mb-0.5">+14%</div>
                  </div>
                </div>
                <div class="h-20 sm:h-24 rounded-xl border border-emerald-500/20 bg-gradient-to-br from-white to-emerald-50/50 p-3 sm:p-4 flex flex-col justify-between shadow-sm relative overflow-hidden hover:shadow-md transition-shadow">
                  <div class="flex justify-between items-start relative z-10">
                    <div class="text-[11px] font-semibold text-emerald-800 leading-tight">Positive Replies</div>
                    <div class="h-6 w-6 rounded-md bg-emerald-100 flex items-center justify-center border border-emerald-200 shrink-0">
                       <svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                  </div>
                  <div class="flex items-end gap-2 relative z-10">
                    <div class="text-2xl font-bold text-emerald-900 leading-none">11.2%</div>
                    <div class="text-[10px] font-medium text-emerald-700 bg-emerald-100/50 px-1.5 py-0.5 rounded-sm mb-0.5">Top 1%</div>
                  </div>
                  <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-emerald-500/10 blur-2xl rounded-full"></div>
                </div>
                <div class="h-20 sm:h-24 rounded-xl border border-zinc-200/80 bg-white p-4 flex flex-col justify-between shadow-sm hover:shadow-md transition-shadow hidden sm:flex">
                  <div class="flex justify-between items-start">
                    <div class="text-[11px] font-semibold text-zinc-500 leading-tight">Pipeline Value</div>
                    <div class="h-6 w-6 rounded-md bg-zinc-50 flex items-center justify-center border border-zinc-100 shrink-0">
                       <svg class="w-3 h-3 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                  </div>
                  <div class="flex items-end gap-2">
                    <div class="text-2xl font-bold text-zinc-900 leading-none">$1.2M</div>
                  </div>
                </div>
              </div>

              {/* Chart Area */}
              <div class="flex-1 rounded-xl border border-zinc-200/80 bg-white p-5 flex flex-col gap-4 relative overflow-hidden shadow-sm">
                <div class="flex justify-between items-center">
                  <div class="text-[12px] font-bold text-zinc-800">Opportunities Sourced</div>
                  <div class="flex gap-2">
                    <div class="text-[10px] font-medium text-zinc-500 bg-zinc-50 px-2 py-1 rounded border border-zinc-200 cursor-pointer hover:bg-zinc-100">Weekly</div>
                    <div class="text-[10px] font-medium text-white bg-zinc-800 px-2 py-1 rounded shadow-sm cursor-pointer">Monthly</div>
                  </div>
                </div>
                
                {/* Animated Chart Columns */}
                <div class="flex-1 flex items-end justify-between gap-3 sm:gap-5 pt-4 relative">
                  {/* Grid lines */}
                  <div class="absolute inset-0 flex flex-col justify-between pointer-events-none pb-0">
                     <div class="w-full h-px bg-zinc-100"></div>
                     <div class="w-full h-px bg-zinc-100"></div>
                     <div class="w-full h-px bg-zinc-100"></div>
                     <div class="w-full h-px bg-zinc-200"></div>
                  </div>
                  
                  <div class="w-full bg-zinc-100 rounded-t-sm relative group chart-bar z-10" style="height: 30%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-300 rounded-t-sm"></div>
                  </div>
                  <div class="w-full bg-zinc-100 rounded-t-sm relative group chart-bar z-10" style="height: 45%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-300 rounded-t-sm"></div>
                  </div>
                  <div class="w-full bg-zinc-100 rounded-t-sm relative group chart-bar z-10" style="height: 40%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-300 rounded-t-sm"></div>
                  </div>
                  <div class="w-full bg-zinc-800 rounded-t-sm relative group chart-bar z-10" style="height: 75%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-900 rounded-t-sm"></div>
                    <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-zinc-900 shadow-lg rounded px-2 py-1 opacity-0 group-hover:opacity-100 transition-opacity z-20 whitespace-nowrap text-[10px] text-white font-bold pointer-events-none">
                      24 Meetings
                      <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-zinc-900 rotate-45"></div>
                    </div>
                  </div>
                  <div class="w-full bg-emerald-500/90 rounded-t-sm relative group chart-bar z-10 shadow-[0_-5px_15px_rgba(16,185,129,0.15)]" style="height: 95%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-emerald-600 rounded-t-sm shadow-[0_0_12px_rgba(16,185,129,0.4)]"></div>
                  </div>
                  <div class="w-full bg-zinc-100 rounded-t-sm relative group chart-bar z-10" style="height: 60%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-300 rounded-t-sm"></div>
                  </div>
                  <div class="w-full bg-zinc-100 rounded-t-sm relative group chart-bar z-10 hidden sm:block" style="height: 80%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-300 rounded-t-sm"></div>
                  </div>
                </div>
                {/* X-axis labels */}
                <div class="flex justify-between items-center mt-2 relative z-10 px-1">
                  <div class="text-[9px] text-zinc-400 font-medium">May</div>
                  <div class="text-[9px] text-zinc-400 font-medium hidden sm:block">Nov</div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Floating Deal Cards */}
        <div class="absolute right-4 sm:right-10 lg:right-14 xl:right-20 bottom-12 sm:bottom-16 lg:bottom-24 h-20 w-52 rounded-xl border border-zinc-200/80 bg-white/95 shadow-[0_20px_40px_rgba(0,0,0,0.1)] backdrop-blur-md p-3.5 flex flex-col justify-center gap-2.5 floating-card-2 z-50 scale-[0.80] sm:scale-100 origin-bottom-right transform hover:scale-[0.85] sm:hover:scale-105 transition-transform">
          <div class="flex justify-between items-center w-full">
            <div class="text-[11px] font-bold text-zinc-800">Warm Lead</div>
            <div class="h-4 px-2 rounded-full bg-emerald-50 border border-emerald-200 flex items-center justify-center text-[9px] font-bold text-emerald-600 tracking-wide">
               $45,000
            </div>
          </div>
          <div class="flex items-center gap-2.5 mt-0.5">
             <div class="flex -space-x-2">
                <div class="w-7 h-7 rounded-full bg-zinc-100 border-2 border-white shadow-sm overflow-hidden flex items-center justify-center">
                  <svg class="w-3.5 h-3.5 text-zinc-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"></path></svg>
                </div>
             </div>
             <div class="flex flex-col gap-0 flex-1">
               <div class="text-[10px] font-semibold text-zinc-700">Marcus Chen</div>
               <div class="text-[9px] text-zinc-400">VP of Revenue Ops, Altus Group</div>
             </div>
          </div>
        </div>
        
        {/* Animated Contract */}
        <div class="contract-wrap absolute -bottom-8 sm:-bottom-12 right-2 sm:-right-8 z-40 flex transform scale-[0.65] sm:scale-75 lg:scale-90 origin-bottom-right">
          <div class="contract-stage">
            <div class="contract-paper" id="contractPaper">
              <div id="contractLines"></div>
              <div class="sig-section">
                <div class="sig-label">AUTHORIZED SIGNATURE</div>
                <div class="sig-dotted"></div>
                <div class="sig-area">
                  <svg id="mainSvg" width="100%" height="68" viewBox="0 0 240 68"
                       style="position:absolute;top:0;left:0;overflow:visible;">
                    <!-- C -->
                    <path class="stroke" fill="none" stroke="#1a1830" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"
                      d="M 28,18 C 22,12 8,12 5,22 C 2,32 6,44 16,47 C 22,49 28,47 32,42"/>
                    <!-- L -->
                    <path class="stroke" fill="none" stroke="#1a1830" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"
                      d="M 42,10 C 41,10 39,48 40,52 C 41,54 48,55 54,53"/>
                    <!-- O -->
                    <path class="stroke" fill="none" stroke="#1a1830" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"
                      d="M 74,22 C 70,15 59,15 57,25 C 55,35 60,48 70,49 C 79,50 84,40 82,30 C 80,20 74,22 74,22"/>
                    <!-- S -->
                    <path class="stroke" fill="none" stroke="#1a1830" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"
                      d="M 108,22 C 104,15 92,14 91,21 C 90,27 97,31 103,34 C 110,37 113,43 108,48 C 104,52 93,51 89,45"/>
                    <!-- E stem -->
                    <path class="stroke" fill="none" stroke="#1a1830" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"
                      d="M 122,14 C 121,14 119,50 120,53"/>
                    <!-- E top arm -->
                    <path class="stroke" fill="none" stroke="#1a1830" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"
                      d="M 121,16 C 124,14 134,14 138,16"/>
                    <!-- E mid arm -->
                    <path class="stroke" fill="none" stroke="#1a1830" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"
                      d="M 120,33 C 123,31 131,31 135,33"/>
                    <!-- E base arm -->
                    <path class="stroke" fill="none" stroke="#1a1830" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"
                      d="M 120,52 C 123,50 134,50 139,52"/>
                    <!-- D stem -->
                    <path class="stroke" fill="none" stroke="#1a1830" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"
                      d="M 150,12 C 149,12 147,50 148,54"/>
                    <!-- D bowl -->
                    <path class="stroke" fill="none" stroke="#1a1830" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round"
                      d="M 149,14 C 158,13 170,18 172,30 C 174,42 165,53 150,53"/>
                    <!-- Pen -->
                    <g id="penG" opacity="0">
                      <g transform="rotate(-38,0,0)">
                        <polygon points="0,0 -4,-14 4,-14" fill="#c4973a"/>
                        <line x1="0" y1="-1" x2="0" y2="-13" stroke="#0e0e1c" stroke-width="0.5" opacity="0.5"/>
                        <rect x="-5" y="-32" width="10" height="19" rx="2" fill="#141420"/>
                        <rect x="-5.5" y="-35" width="11" height="4" rx="1" fill="#c4973a"/>
                        <rect x="-5" y="-100" width="10" height="66" rx="3" fill="#1c1c2e"/>
                        <rect x="-5.5" y="-104" width="11" height="7" rx="3" fill="#24243a"/>
                        <rect x="5" y="-101" width="2" height="58" rx="1" fill="#c4973a"/>
                        <circle cx="6" cy="-101" r="2" fill="#c4973a"/>
                        <rect x="-4" y="-99" width="1.5" height="60" rx="0.7" fill="rgba(255,255,255,0.07)"/>
                      </g>
                    </g>
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>

        </div>

      </div>
    </div>
  </section>
</div>

<style>
  .hero-section-wrapper {
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .perspective-1000 {
    perspective: 1200px;
  }
  
  .rotate-y-\[-4deg\] {
    transform: rotateY(-4deg);
  }
  
  .rotate-x-\[2deg\] {
    transform: rotateX(2deg);
  }

  /* Contract styles */
  .contract-wrap {
    display: flex;
    justify-content: center;
    perspective: 900px;
    perspective-origin: 50% 20%;
    animation: floatCard2 9s ease-in-out infinite;
    animation-delay: 2s;
  }
  .contract-stage {
    transform: rotateX(24deg) rotateY(-3deg);
    transform-origin: center top;
    width: 280px;
  }
  .contract-paper {
    background: #faf9f6;
    border-radius: 4px;
    border: 0.5px solid rgba(0,0,0,0.1);
    box-shadow: 0 8px 32px rgba(0,0,0,0.10), 0 2px 8px rgba(0,0,0,0.07);
    padding: 20px 22px 18px;
    position: relative;
  }
  :global(.c-line) {
    height: 2px;
    border-radius: 1px;
    background: #e5e2dc;
    margin-bottom: 8px;
    transform-origin: left;
    animation: lineIn 0.35s ease both;
  }
  @keyframes lineIn {
    from { transform: scaleX(0); opacity: 0; }
    to   { transform: scaleX(1); opacity: 1; }
  }
  .sig-section {
    border-top: 0.5px solid #ddd;
    padding-top: 10px;
  }
  .sig-label {
    font-family: -apple-system, sans-serif;
    font-size: 7px;
    letter-spacing: 1.4px;
    color: #bbb;
    margin-bottom: 6px;
  }
  .sig-dotted {
    border-bottom: 1px dashed #ccc;
    width: 100%;
  }
  .sig-area {
    position: relative;
    height: 68px;
  }

  /* Animations for dashboard visual */
  .dashboard-window {
    animation: float 10s ease-in-out infinite;
    will-change: transform;
  }

  .chart-bar {
    animation: growBar 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    transform-origin: bottom;
    transform: scaleY(0);
    will-change: transform, opacity;
  }

  .chart-bar:nth-child(2) { animation-delay: 0.05s; }
  .chart-bar:nth-child(3) { animation-delay: 0.1s; }
  .chart-bar:nth-child(4) { animation-delay: 0.15s; }
  .chart-bar:nth-child(5) { animation-delay: 0.2s; }
  .chart-bar:nth-child(6) { animation-delay: 0.25s; }
  .chart-bar:nth-child(7) { animation-delay: 0.3s; }
  .chart-bar:nth-child(8) { animation-delay: 0.35s; }

  .progress-bar-1 {
    animation: fillProgress1 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    width: 0;
  }

  .floating-card-1 {
    animation: floatCard1 8s ease-in-out infinite;
    will-change: transform;
  }

  .floating-card-2 {
    animation: floatCard2 9s ease-in-out infinite;
    animation-delay: 1.5s;
    will-change: transform;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0) rotateY(-4deg) rotateX(2deg);
    }
    50% {
      transform: translateY(-12px) rotateY(-1deg) rotateX(5deg);
    }
  }

  @keyframes growBar {
    0% {
      transform: scaleY(0);
      opacity: 0;
    }
    100% {
      transform: scaleY(1);
      opacity: 1;
    }
  }

  @keyframes fillProgress1 {
    0% { width: 0; }
    100% { width: 85%; }
  }

  @keyframes floatCard1 {
    0%, 100% {
      transform: translateY(0) translateX(0);
    }
    50% {
      transform: translateY(-15px) translateX(8px);
    }
  }

  @keyframes floatCard2 {
    0%, 100% {
      transform: translateY(0) translateX(0);
    }
    50% {
      transform: translateY(12px) translateX(-10px);
    }
  }
</style>

<script>
  function initHeroCanvas() {
    const canvas = document.getElementById("c") as HTMLCanvasElement | null;
    const ctx = canvas?.getContext("2d");
    const wrap = document.getElementById("hero-wrap");

    if (!canvas || !ctx || !wrap) return;

    if ((canvas as any)._isAnimating) return;
    (canvas as any)._isAnimating = true;

    let W: number = 0, H: number = 0;
    let t = 0;
    let animationFrameId: number;

    function resize() {
      if (!wrap || !canvas || !ctx) return;
      W = wrap.offsetWidth;
      H = wrap.offsetHeight;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      ctx.scale(dpr, dpr);
    }
    
    const ro = new ResizeObserver(() => resize());
    ro.observe(wrap);
    resize();

    function noise(x: number, y: number, t: number) {
      const v1 =
        Math.sin(x * 0.008 + t * 0.18) * Math.cos(y * 0.009 - t * 0.12);
      const v2 = Math.sin(x * 0.014 - y * 0.007 + t * 0.09);
      const v3 = Math.cos(x * 0.006 + y * 0.011 - t * 0.15) * 0.5;
      const v4 = Math.sin((x + y) * 0.005 + t * 0.07) * 0.3;
      return (v1 + v2 + v3 + v4) / 2.3;
    }

    function getIsoLines(levels: number[]) {
      const step = 14;
      const cols = Math.ceil(W / step) + 1;
      const rows = Math.ceil(H / step) + 1;

      const grid: number[][] = [];
      for (let r = 0; r < rows; r++) {
        grid[r] = [];
        for (let c = 0; c < cols; c++) {
          grid[r][c] = noise(c * step, r * step, t);
        }
      }

      const lines: Record<number, number[][][]> = {};
      levels.forEach((lv) => (lines[lv] = []));

      for (let r = 0; r < rows - 1; r++) {
        for (let c = 0; c < cols - 1; c++) {
          const x0 = c * step,
            y0 = r * step;
          const tl = grid[r][c],
            tr = grid[r][c + 1];
          const bl = grid[r + 1][c],
            br = grid[r + 1][c + 1];

          levels.forEach((lv) => {
            const pts: number[][] = [];

            function interp(
              ax: number,
              ay: number,
              av: number,
              bx: number,
              by: number,
              bv: number,
            ) {
              if (av < lv === bv < lv) return;
              const s = (lv - av) / (bv - av);
              pts.push([ax + (bx - ax) * s, ay + (by - ay) * s]);
            }

            interp(x0, y0, tl, x0 + step, y0, tr);
            interp(x0 + step, y0, tr, x0 + step, y0 + step, br);
            interp(x0, y0 + step, bl, x0 + step, y0 + step, br);
            interp(x0, y0, tl, x0, y0 + step, bl);

            if (pts.length === 2) {
              lines[lv].push(pts);
            }
          });
        }
      }

      return lines;
    }

    function draw() {
      t += 0.012;
      ctx!.clearRect(0, 0, W, H);

      const levelCount = 22;
      const levels: number[] = [];
      for (let i = 0; i < levelCount; i++) {
        levels.push(-1.05 + (i / (levelCount - 1)) * 2.1);
      }

      const isoLines = getIsoLines(levels);

      levels.forEach((lv, idx) => {
        const segs = isoLines[lv];
        if (!segs || !segs.length) return;

        const t_norm = idx / (levelCount - 1);
        const isMid = t_norm > 0.3 && t_norm < 0.7;

        // Restore original low opacity values
        const baseAlpha = isMid ? 0.10 : 0.06;

        const r = 0;
        const g = 0;
        const b = 0;

        ctx!.strokeStyle = `rgba(${r},${g},${b},${baseAlpha})`;
        ctx!.lineWidth = isMid ? 1.2 : 0.8;
        ctx!.lineCap = "round";
        ctx!.lineJoin = "round";

        segs.forEach(([p1, p2]) => {
          ctx!.beginPath();
          ctx!.moveTo(p1[0], p1[1]);
          ctx!.lineTo(p2[0], p2[1]);
          ctx!.stroke();
        });
      });

      animationFrameId = requestAnimationFrame(draw);
    }

    draw();

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationFrameId);
      ro.disconnect();
      if (canvas) (canvas as any)._isAnimating = false;
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initHeroCanvas);
  initHeroCanvas();

  function initContractAnimation() {
    const linesEl = document.getElementById('contractLines');
    if (!linesEl) return;
    
    linesEl.innerHTML = ''; 
    
    [85,68,80,60,75,55,70,62,52].forEach(function(pct, i){
      const l = document.createElement('div');
      l.className = 'c-line';
      l.style.width = pct + '%';
      l.style.animationDelay = (0.4 + i * 0.05) + 's';
      linesEl.appendChild(l);
    });

    const strokes   = Array.from(document.querySelectorAll('.stroke')) as SVGPathElement[];
    const penG      = document.getElementById('penG') as SVGGElement | null;
    if (!penG || !strokes.length) return;
    
    const durations = [540, 380, 480, 480, 320, 160, 160, 160, 280, 420];
    const LIFT_DUR  = 120;
    const HOLD      = 900;
    const PAUSE     = 2200;
    const FLY_DUR   = 520;

    function easeInOut(t: number){ return t < 0.5 ? 2*t*t : -1+(4-2*t)*t; }

    function runCycle(){
      if (!document.getElementById('contractLines')) return;
      
      strokes.forEach(function(p){
        var len = p.getTotalLength();
        p.setAttribute('stroke-dasharray', String(len));
        p.setAttribute('stroke-dashoffset', String(len));
        p.style.opacity = '1';
        p.style.transition = 'none';
      });
      penG!.setAttribute('opacity','0');

      var firstPt = strokes[0].getPointAtLength(0);
      var flyT0   = performance.now() + 850;

      function flyFrame(now: number){
        if (!document.getElementById('contractLines')) return;
        var t = Math.min((now - flyT0) / FLY_DUR, 1);
        if(t <= 0){ requestAnimationFrame(flyFrame); return; }
        var e = easeInOut(t);
        penG!.setAttribute('transform','translate('+(220+(firstPt.x-220)*e)+','+((-52)+(firstPt.y+52)*e)+')');
        penG!.setAttribute('opacity', String(Math.min(t*3,1)));
        if(t < 1) requestAnimationFrame(flyFrame);
        else      writeStroke(0);
      }
      requestAnimationFrame(flyFrame);

      function writeStroke(idx: number){
        if (!document.getElementById('contractLines')) return;
        if(idx >= strokes.length){ setTimeout(liftAndEnd, HOLD); return; }
        var path  = strokes[idx];
        var total = path.getTotalLength();
        var dur   = durations[idx] || 300;
        var t0    = performance.now();
        function frame(now: number){
          if (!document.getElementById('contractLines')) return;
          var raw  = Math.min((now - t0) / dur, 1);
          var ease = easeInOut(raw);
          var drawn = ease * total;
          path.setAttribute('stroke-dashoffset', String(total - drawn));
          var pt = path.getPointAtLength(drawn);
          penG!.setAttribute('transform','translate('+pt.x+','+pt.y+')');
          if(raw < 1) requestAnimationFrame(frame);
          else {
            if(idx + 1 < strokes.length)
              liftToNext(pt, strokes[idx+1].getPointAtLength(0), function(){ writeStroke(idx+1); });
            else
              writeStroke(idx+1);
          }
        }
        requestAnimationFrame(frame);
      }

      function liftToNext(from: {x: number, y: number}, to: {x: number, y: number}, cb: () => void){
        var t0 = performance.now();
        function frame(now: number){
          if (!document.getElementById('contractLines')) return;
          var t = Math.min((now - t0) / LIFT_DUR, 1);
          var e = easeInOut(t);
          var mx = from.x + (to.x - from.x) * e;
          var my = from.y + (to.y - from.y) * e - Math.sin(e * Math.PI) * 10;
          penG!.setAttribute('transform','translate('+mx+','+my+')');
          if(t < 1) requestAnimationFrame(frame); else cb();
        }
        requestAnimationFrame(frame);
      }

      function liftAndEnd(){
        var last   = strokes[strokes.length - 1];
        var lastPt = last.getPointAtLength(last.getTotalLength());
        var t0     = performance.now();
        var LDUR   = 420;
        function frame(now: number){
          if (!document.getElementById('contractLines')) return;
          var t = Math.min((now - t0) / LDUR, 1);
          var e = easeInOut(t);
          penG!.setAttribute('transform','translate('+(lastPt.x+e*44)+','+(lastPt.y-e*46)+')');
          penG!.setAttribute('opacity', String(1 - e));
          if(t < 1) requestAnimationFrame(frame);
          else {
            penG!.setAttribute('opacity','0');
            setTimeout(function(){
              if (!document.getElementById('contractLines')) return;
              strokes.forEach(function(p){ p.style.transition='opacity 0.35s'; p.style.opacity='0'; });
              setTimeout(runCycle, 380);
            }, PAUSE);
          }
        }
        requestAnimationFrame(frame);
      }
    }

    let timer = setTimeout(runCycle, 700) as any;
    document.addEventListener('astro:before-swap', () => {
      clearTimeout(timer);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initContractAnimation);
  initContractAnimation();
</script>
