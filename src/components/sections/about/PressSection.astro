---
import { Image } from 'astro:assets';
import Icon from '@components/ui/icons/Icon.astro';

const pressArticles = [
  {
    publication: 'Ziarul Financiar',
    title: 'ZF IT Generation Start-up Pitch: Cosmin Coția, Ovidiu Tulbure',
    date: '13 Nov 2025',
    url: 'https://www.zf.ro/zf-it-generation/zf-it-generation-start-up-pitch-cosmin-cotia-ovidiu-tulbure-22949936',
    logo: 'https://www.brainsymphony.tech/_astro/zf.z-Zg34Qc.png',
  },
  {
    publication: 'Profit.ro',
    title:
      'Realitate virtuală pentru sănătate mintală. Cosmin Cotia, co-fondator BrainSymphony',
    date: '14 May 2026',
    url: 'https://www.profit.ro/profit-live/video-realitate-virtuala-sanatate-mintala-cosmin-cotia-co-fondator-brainsymphony-mijlocul-anului-2026-vrem-deschidem-prima-runda-finantare-vizam-china-extindere-profit-live-tv-22309010',
    logo: 'https://www.brainsymphony.tech/_astro/profit.BhJA7f91.png',
  },
  {
    publication: 'start-up.ro',
    title:
      'Startup românesc care aduce meditația în realitatea virtuală pentru reducerea stresului',
    date: '21 Jan 2026',
    url: 'https://start-up.ro/startup-romanesc-care-aduce-meditatia-in-realitatea-virtuala-pentru-reducerea-stresului/',
    logo: 'https://www.brainsymphony.tech/_astro/startup.BK1nfEkS.png',
  },
  {
    publication: 'Podcastul lui Tibi Goanță',
    title: 'Brain Symphony: Redefinirea Sănătății Mintale prin VR',
    date: '08 Mar 2026',
    url: 'https://www.youtube.com/watch?v=CI8Ktzs5OXs',
    logo: null,
  },
];

const { title, subTitle } = Astro.props;

interface Props {
  title: string;
  subTitle: string;
}
---

<section class="content-container py-16 lg:py-24">
  <div class="mb-12 max-w-2xl">
    <h2
      class="text-brand-text dark:text-brand-text/90 text-3xl font-bold tracking-tight sm:text-4xl"
    >
      {title}
    </h2>
    <p class="text-brand-text/70 dark:text-brand-text/60 mt-4 text-lg">
      {subTitle}
    </p>
  </div>

  <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-4">
    {
      pressArticles.map(article => (
        <a
          href={article.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group premium-card flex flex-col justify-between p-6 transition-all duration-300 hover:-translate-y-1"
        >
          <div>
            <div class="mb-4 flex h-12 items-center">
              {article.logo ? (
                <img
                  src={article.logo}
                  alt={article.publication}
                  class="max-h-full max-w-[140px] object-contain grayscale transition duration-300 group-hover:grayscale-0"
                />
              ) : (
                <span class="text-brand-text/40 dark:text-brand-text/30 text-lg font-bold">
                  {article.publication}
                </span>
              )}
            </div>
            <h3 class="text-brand-text group-hover:text-brand-accent-1 dark:text-brand-text/90 line-clamp-3 text-lg font-bold transition">
              {article.title}
            </h3>
          </div>
          <div class="mt-6 flex items-center justify-between">
            <span class="text-brand-text/50 dark:text-brand-text/40 text-sm">
              {article.date}
            </span>
            <div class="text-brand-accent-1 opacity-0 transition-all duration-300 group-hover:translate-x-1 group-hover:opacity-100">
              <Icon name="openInNew" class="h-4 w-4" />
            </div>
          </div>
        </a>
      ))
    }
  </div>
</section>
