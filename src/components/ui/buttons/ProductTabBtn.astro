---
// Destructure the properties from Astro.props
const { id, dataTab, title, first } = Astro.props;

// Define TypeScript interface for the properties
interface Props {
  id: string;
  dataTab: string;
  title: string;
  first?: boolean;
}
// Define constants for styling classes
const BUTTON_CLASS =
  'group flex w-full justify-center gap-x-[8px] rounded-[8px] border px-[24px] py-[12px] text-[14px] font-medium outline-hidden transition-colors duration-150 ease-out active:scale-[0.98]';

const HEADING_CLASS = 'block text-center';
const INACTIVE_HEADING_CLASS = 'text-[#0f0f0f]';
---

{/* Tab button element */}
<button
  type="button"
  class={`${BUTTON_CLASS} ${first ? 'active bg-[#0f0f0f] text-white border-transparent hover:bg-[#2a2a2a]' : 'bg-transparent text-[#0f0f0f] border-[#0f0f0f] hover:bg-[#0f0f0f] hover:text-white'}`}
  id={id}
  data-target={dataTab}
  role="tab"
>
  {/* Tab text */}
  <span
    class={`${HEADING_CLASS} ${first ? 'text-brand-accent-1' : INACTIVE_HEADING_CLASS}`}
  >
    {title}
  </span>
</button>
