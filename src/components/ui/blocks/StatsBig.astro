---
// Extract the properties from Astro.props
const { title, subTitle } = Astro.props;
// Define TypeScript interface for the properties
interface Props {
  title: string;
  subTitle: string;
}
---

{/* Container for the title and subtitle */}
<div class="lg:pe-6 xl:pe-12">
  <p
    class="text-brand-accent-1 dark:text-brand-accent-1/90 text-6xl leading-10 font-bold"
  >
    {title}
  </p>
  <p class="text-brand-text/70 dark:text-brand-text/60 mt-2 sm:mt-3">
    {subTitle}
  </p>
</div>
