---
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/misc/ContactSection.astro";
import { useTranslations } from "@/copywriting";

const copy = useTranslations();
const pageCopy = copy.pages.home;

const pageTitle = pageCopy.metaTitle || "Sparrow | Outbound Sales Partnership";
const metaDescription =
  pageCopy.metaDescription || "We Build, Manage, and Close Your B2B Pipeline.";
---

<MainLayout title={pageTitle} customDescription={metaDescription}>
  {/* Core Container */}
  <div
    class="outbound-page-wrapper relative min-h-screen overflow-hidden bg-[#f7f7f5] text-zinc-800"
  >
    {/* Ambient Organic Glow Backgrounds */}
    <div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div
        class="dot-grid absolute inset-0 opacity-[0.04] bg-[radial-gradient(#999_1px,transparent_1px)] bg-[size:24px_24px]"
      >
      </div>
    </div>

    {/* Hero Section */}
    <div
      class="relative z-10 flex min-h-[92vh] items-center pt-24 lg:pt-0 overflow-hidden"
      id="hero-wrap"
    >
      <canvas
        id="c"
        class="absolute inset-0 w-full h-full pointer-events-none -z-10"
        style="mask-image: radial-gradient(ellipse 70% 70% at 50% 55%, transparent 35%, black 85%); -webkit-mask-image: radial-gradient(ellipse 70% 70% at 50% 55%, transparent 35%, black 85%);"
      ></canvas>

      <div
        class="content-container relative z-10 w-full py-20 lg:py-32 flex flex-col items-center justify-center"
      >
        <div class="flex max-w-4xl flex-col items-center text-center">
          <div class="reveal-element mb-6 flex items-center justify-center">
            <span class="text-[11px] tracking-[0.12em] text-[#999] uppercase"
              >{pageCopy.hero.eyebrowLabel}</span
            >
          </div>

          <h1
            class="reveal-heading font-display mb-6 text-4xl leading-[1.08] font-bold tracking-[-0.02em] text-zinc-950 sm:text-6xl text-center text-balance"
          >
            <Fragment set:html={pageCopy.hero.titleHtml} />
          </h1>

          <p
            class="reveal-element mx-auto mb-10 max-w-[520px] text-center text-lg leading-relaxed font-light text-zinc-600 sm:text-xl"
          >
            {pageCopy.hero.subTitle}
          </p>

          <div
            class="reveal-element flex w-full flex-col gap-4 sm:w-auto sm:flex-row justify-center"
          >
            <a
              href={pageCopy.hero.primaryBtnURL}
              class="group inline-flex items-center justify-center gap-x-2 rounded-[6px] px-5 py-3 text-sm font-medium ring-zinc-500 transition duration-300 focus-visible:ring-3 outline-hidden bg-[#0f0f0f] hover:bg-[#1a1a1a] active:bg-black text-white 2xl:text-base"
            >
              {pageCopy.hero.primaryBtn}
            </a>
          </div>
        </div>
      </div>
    </div>

    {/* Section 2: Agitation */}
    <section
      id="approach"
      class="relative z-10 border-y border-zinc-200 bg-zinc-50/50 py-24 backdrop-blur-sm lg:py-32"
    >
      <div
        class="pointer-events-none absolute top-1/2 left-1/2 h-[250px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-accent-1/5 blur-[120px]"
      >
      </div>

      <div class="content-container relative z-10">
        <div class="mx-auto max-w-4xl">
          <div class="reveal-element mb-8 flex justify-center">
            <div
              class="flex h-12 w-12 items-center justify-center rounded-full border border-brand-accent-1/20 bg-brand-accent-1/5 shadow-[0_0_20px_rgba(13,45,138,0.1)]"
            >
              <div class="h-2 w-2 rounded-full bg-brand-accent-1"></div>
            </div>
          </div>

          <h2
            class="reveal-heading font-display mb-8 text-center text-3xl leading-tight font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.agitation.titleHtml} />
          </h2>

          <div
            class="reveal-element mx-auto mb-10 h-[1px] w-24 bg-gradient-to-r from-transparent via-brand-accent-1/40 to-transparent"
          >
          </div>

          <p
            class="reveal-element mx-auto mb-12 max-w-3xl text-center text-lg leading-relaxed font-light text-zinc-600 sm:text-xl"
          >
            {pageCopy.agitation.subTitle}
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
              pageCopy.agitation.stats.map((stat) => (
                <div class="premium-card p-6 text-center">
                  <div class="text-4xl font-bold text-brand-accent-1 mb-2">
                    {stat.stat}
                  </div>
                  <p class="text-zinc-600 font-medium">{stat.description}</p>
                </div>
              ))
            }
          </div>

          <p
            class="reveal-element mx-auto mt-12 max-w-3xl text-center text-lg font-medium text-zinc-800"
          >
            {pageCopy.agitation.conclusion}
          </p>
        </div>
      </div>
    </section>

    {/* Section 3: Solution (Hybrid Model) */}
    <section
      class="relative z-10 bg-transparent py-20 lg:py-28 border-b border-zinc-200"
    >
      <div class="content-container">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2
            class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.solution.titleHtml} />
          </h2>
          <p
            class="reveal-element text-lg font-light text-zinc-600 whitespace-pre-line"
          >
            {pageCopy.solution.subTitle}
          </p>
        </div>

        <div
          class="reveal-grid mx-auto grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-3"
        >
          {
            pageCopy.solution.items.map((item, idx) => (
              <div class="premium-card group relative p-8">
                <h3 class="font-display mb-4 text-xl font-bold text-zinc-900 group-hover:text-brand-accent-1 transition-colors duration-300">
                  {item.title}
                </h3>
                <p class="text-base leading-relaxed text-zinc-600">
                  {item.content}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* Section 4: Process */}
    <section
      id="capabilities"
      class="relative z-10 scroll-mt-24 py-24 lg:py-36 bg-zinc-50/50"
    >
      <div class="content-container">
        <div class="mx-auto mb-20 max-w-3xl text-center">
          <h2
            class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.process.titleHtml} />
          </h2>
          <p class="reveal-element text-lg font-light text-zinc-600">
            {pageCopy.process.subTitle}
          </p>
        </div>

        <div class="reveal-grid relative grid grid-cols-1 gap-8 md:grid-cols-3">
          {
            pageCopy.process.phases.map((phase, idx) => (
              <div class="group relative overflow-hidden rounded-2xl border border-zinc-200 bg-white p-8 transition-all duration-500 hover:-translate-y-1 hover:border-brand-accent-1/30 hover:shadow-xl hover:shadow-brand-accent-1/10">
                {/* Animated background gradient on hover */}
                <div class="absolute inset-0 bg-gradient-to-br from-brand-accent-1/5 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100" />

                {/* Icon container */}
                <div class="mb-8 flex h-12 w-12 items-center justify-center rounded-xl border transition-transform duration-500 group-hover:scale-110 border-brand-accent-1/20 bg-brand-accent-1/5 group-hover:border-brand-accent-1 text-brand-accent-1">
                  <svg
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    {idx === 0 && (
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
                      />
                    )}
                    {idx === 1 && (
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                      />
                    )}
                    {idx === 2 && (
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"
                      />
                    )}
                  </svg>
                </div>
                <h3 class="font-display mb-4 text-2xl font-bold text-zinc-900 transition-colors duration-300 group-hover:text-brand-accent-1">
                  {phase.title}
                </h3>
                <p class="text-base leading-relaxed text-zinc-600">
                  {phase.content}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* Section 5: Analytics */}
    <section
      class="relative z-10 bg-transparent py-20 lg:py-28 border-b border-zinc-200"
    >
      <div class="content-container">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2
            class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.analytics.titleHtml} />
          </h2>
          <p
            class="reveal-element text-lg font-light text-zinc-600 whitespace-pre-line"
          >
            {pageCopy.analytics.subTitle}
          </p>
        </div>

        <div
          class="reveal-grid mx-auto grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-3"
        >
          {
            pageCopy.analytics.items.map((item, idx) => (
              <div class="premium-card group relative p-8 text-center border-t-4 border-t-transparent hover:border-t-brand-accent-1 transition-all">
                <h3 class="font-display mb-4 text-xl font-bold text-zinc-900 group-hover:text-brand-accent-1 transition-colors duration-300">
                  {item.title}
                </h3>
                <p class="text-base leading-relaxed text-zinc-600">
                  {item.content}
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    {/* Section 6: Pricing */}
    <section
      id="pricing"
      class="relative z-10 scroll-mt-24 border-t border-zinc-200 bg-zinc-50/50 py-24 lg:py-36"
    >
      <div
        class="pointer-events-none absolute right-0 bottom-0 h-[400px] w-[400px] rounded-full bg-brand-accent-1/5 blur-[120px]"
      >
      </div>

      <div class="content-container relative z-10">
        <div class="mx-auto mb-20 max-w-2xl text-center">
          <h2
            class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.pricing.titleHtml} />
          </h2>
          <p
            class="reveal-element text-lg leading-relaxed font-light text-zinc-600"
          >
            {pageCopy.pricing.subTitle}
          </p>
        </div>

        <div
          class="reveal-grid mx-auto grid max-w-6xl grid-cols-1 items-stretch gap-8 lg:grid-cols-3"
        >
          {/* Starter */}
          <div
            class="relative flex flex-col rounded-3xl border border-zinc-200 bg-white p-8 shadow-sm transition-all duration-300 hover:border-brand-accent-1/20 hover:shadow-lg"
          >
            <div class="mb-6">
              <h3 class="font-display text-2xl font-bold text-zinc-900">
                {pageCopy.pricing.plans.starter.title}
              </h3>
              <p class="mt-2 text-sm text-zinc-600 h-10">
                {pageCopy.pricing.plans.starter.description}
              </p>
            </div>
            <div class="mb-8">
              <div class="flex items-baseline gap-1">
                <div class="text-3xl font-bold text-brand-accent-1">
                  {pageCopy.pricing.plans.starter.price}
                </div>
              </div>
            </div>
            <ul class="mb-8 flex-1 space-y-4 text-sm text-zinc-700">
              {
                pageCopy.pricing.plans.starter.features.map((f) => (
                  <li class="flex items-start gap-3">
                    <svg
                      class="mt-1 h-4 w-4 shrink-0 text-brand-accent-1"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="3"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {f}
                  </li>
                ))
              }
            </ul>
            <a
              href="#audit"
              class="mt-8 w-full inline-flex items-center justify-center gap-x-2 rounded-lg border border-zinc-300 bg-white px-4 py-3 text-center text-xs font-mono font-medium uppercase tracking-wider text-zinc-700 shadow-xs transition duration-300 hover:bg-brand-accent-1/10 hover:text-brand-accent-1 hover:border-brand-accent-1/40 active:bg-brand-accent-1/20 outline-hidden ring-zinc-500 focus-visible:ring-3"
            >
              Get Started
            </a>
          </div>

          {/* Growth */}
          <div
            class="premium-card group relative flex flex-col justify-between p-8 border-brand-accent-1/30 shadow-[0_0_30px_rgba(var(--brand-accent-1-rgb),0.1)]"
          >
            <div
              class="absolute -top-[14px] left-1/2 -translate-x-1/2 rounded-full bg-brand-accent-1 px-4 py-1 font-mono text-[9px] font-bold tracking-widest text-white uppercase shadow-[0_4px_12px_rgba(var(--brand-accent-1-rgb),0.15)] z-20"
            >
              {pageCopy.pricing.plans.growth.badge}
            </div>
            <div>
              <div class="mb-8">
                <h3 class="font-display mb-2 text-2xl font-bold text-zinc-900">
                  {pageCopy.pricing.plans.growth.title}
                </h3>
                <p class="text-sm text-zinc-500 mb-4 h-10">
                  {pageCopy.pricing.plans.growth.description}
                </p>
                <div class="text-3xl font-bold text-brand-accent-1">
                  {pageCopy.pricing.plans.growth.price}
                </div>
              </div>
              <div class="my-6 h-[1px] w-full bg-zinc-200"></div>
              <ul class="mb-10 space-y-4 text-sm text-zinc-700">
                {
                  pageCopy.pricing.plans.growth.features.map((f) => (
                    <li class="flex items-start gap-3">
                      <svg
                        class="mt-1 h-4 w-4 shrink-0 text-brand-accent-1"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="3"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                      {f}
                    </li>
                  ))
                }
              </ul>
            </div>
            <a
              href="#audit"
              class="mt-8 w-full inline-flex items-center justify-center gap-x-2 rounded-lg bg-brand-accent-1 px-4 py-3 text-center text-xs font-mono font-bold uppercase tracking-wider text-white shadow-[0_4px_12px_rgba(var(--brand-accent-1-rgb),0.25)] transition duration-300 hover:bg-brand-accent-1/90 hover:shadow-[0_6px_20px_rgba(var(--brand-accent-1-rgb),0.35)] outline-hidden ring-zinc-500 focus-visible:ring-3"
            >
              Get Started
            </a>
          </div>

          {/* Scale */}
          <div
            class="relative flex flex-col rounded-3xl border border-zinc-200 bg-white p-8 shadow-sm transition-all duration-300 hover:border-brand-accent-1/20 hover:shadow-lg"
          >
            <div class="mb-6">
              <h3 class="font-display text-2xl font-bold text-zinc-900">
                {pageCopy.pricing.plans.scale.title}
              </h3>
              <p class="mt-2 text-sm text-zinc-600 h-10">
                {pageCopy.pricing.plans.scale.description}
              </p>
            </div>
            <div class="mb-8">
              <div class="flex items-baseline gap-1">
                <div class="text-3xl font-bold text-brand-accent-1">
                  {pageCopy.pricing.plans.scale.price}
                </div>
              </div>
            </div>
            <ul class="mb-8 flex-1 space-y-4 text-sm text-zinc-700">
              {
                pageCopy.pricing.plans.scale.features.map((f) => (
                  <li class="flex items-start gap-3">
                    <svg
                      class="mt-1 h-4 w-4 shrink-0 text-brand-accent-1"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="3"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {f}
                  </li>
                ))
              }
            </ul>
            <a
              href="#audit"
              class="mt-8 w-full inline-flex items-center justify-center gap-x-2 rounded-lg border border-zinc-300 bg-white px-4 py-3 text-center text-xs font-mono font-medium uppercase tracking-wider text-zinc-700 shadow-xs transition duration-300 hover:bg-brand-accent-1/10 hover:text-brand-accent-1 hover:border-brand-accent-1/40 active:bg-brand-accent-1/20 outline-hidden ring-zinc-500 focus-visible:ring-3"
            >
              Get Started
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Section 7: Final CTA & Contact */}
    <section id="audit" class="relative z-10 bg-white py-24 lg:py-36">
      <div class="content-container">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <h2
            class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.cta.titleHtml} />
          </h2>
          <p
            class="reveal-element text-lg font-light text-zinc-600 whitespace-pre-line"
          >
            {pageCopy.cta.subTitle}
          </p>
        </div>

        {
          /* Contact Form Container (hidden title from contact section for seamless integration) */
        }
        <div class="hide-contact-title">
          <ContactSection />
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<style is:global>
  /* Premium Card Styles */
  .premium-card {
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: rgba(250, 250, 250, 0.5);
    transition: all 0.3s ease-in-out;
  }
  .premium-card:hover {
    background: white;
    border-color: rgba(37, 99, 235, 0.2);
    box-shadow: 0 10px 40px -10px rgba(0, 0, 0, 0.08);
  }

  /* Utility to hide Contact Section's native title to avoid redundancy with the CTA */
  .hide-contact-title h1,
  .hide-contact-title p.text-pretty {
    display: none !important;
  }
</style>

<script>
  const canvas = document.getElementById("c") as HTMLCanvasElement;
  const ctx = canvas?.getContext("2d");
  const wrap = document.getElementById("hero-wrap");

  if (canvas && ctx && wrap) {
    let W: number, H: number;
    function resize() {
      W = wrap!.offsetWidth;
      H = wrap!.offsetHeight;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      ctx!.scale(dpr, dpr);
    }
    resize();
    window.addEventListener("resize", resize);

    let t = 0;

    function noise(x: number, y: number, t: number) {
      const v1 =
        Math.sin(x * 0.008 + t * 0.18) * Math.cos(y * 0.009 - t * 0.12);
      const v2 = Math.sin(x * 0.014 - y * 0.007 + t * 0.09);
      const v3 = Math.cos(x * 0.006 + y * 0.011 - t * 0.15) * 0.5;
      const v4 = Math.sin((x + y) * 0.005 + t * 0.07) * 0.3;
      return (v1 + v2 + v3 + v4) / 2.3;
    }

    function getIsoLines(levels: number[]) {
      const step = 6;
      const cols = Math.ceil(W / step) + 1;
      const rows = Math.ceil(H / step) + 1;

      const grid: number[][] = [];
      for (let r = 0; r < rows; r++) {
        grid[r] = [];
        for (let c = 0; c < cols; c++) {
          grid[r][c] = noise(c * step, r * step, t);
        }
      }

      const lines: Record<number, number[][][]> = {};
      levels.forEach((lv) => (lines[lv] = []));

      for (let r = 0; r < rows - 1; r++) {
        for (let c = 0; c < cols - 1; c++) {
          const x0 = c * step,
            y0 = r * step;
          const tl = grid[r][c],
            tr = grid[r][c + 1];
          const bl = grid[r + 1][c],
            br = grid[r + 1][c + 1];

          levels.forEach((lv) => {
            const pts: number[][] = [];

            function interp(
              ax: number,
              ay: number,
              av: number,
              bx: number,
              by: number,
              bv: number,
            ) {
              if (av < lv === bv < lv) return;
              const s = (lv - av) / (bv - av);
              pts.push([ax + (bx - ax) * s, ay + (by - ay) * s]);
            }

            interp(x0, y0, tl, x0 + step, y0, tr);
            interp(x0 + step, y0, tr, x0 + step, y0 + step, br);
            interp(x0, y0 + step, bl, x0 + step, y0 + step, br);
            interp(x0, y0, tl, x0, y0 + step, bl);

            if (pts.length === 2) {
              lines[lv].push(pts);
            }
          });
        }
      }

      return lines;
    }

    function draw() {
      t += 0.012;
      ctx!.clearRect(0, 0, W, H);

      const levelCount = 22;
      const levels: number[] = [];
      for (let i = 0; i < levelCount; i++) {
        levels.push(-1.05 + (i / (levelCount - 1)) * 2.1);
      }

      const isoLines = getIsoLines(levels);

      levels.forEach((lv, idx) => {
        const segs = isoLines[lv];
        if (!segs || !segs.length) return;

        const t_norm = idx / (levelCount - 1);
        const isMid = t_norm > 0.3 && t_norm < 0.7;

        const baseAlpha = isMid ? 0.08 : 0.05;
        const blueBlend = isMid ? 0.4 : 0.1;

        const r = 0;
        const g = 0;
        const b = 0;

        ctx!.strokeStyle = `rgba(${r},${g},${b},${baseAlpha})`;
        ctx!.lineWidth = isMid ? 1.1 : 0.7;
        ctx!.lineCap = "round";
        ctx!.lineJoin = "round";

        segs.forEach(([p1, p2]) => {
          ctx!.beginPath();
          ctx!.moveTo(p1[0], p1[1]);
          ctx!.lineTo(p2[0], p2[1]);
          ctx!.stroke();
        });
      });

      requestAnimationFrame(draw);
    }

    draw();
  }
</script>
