---
//Import relevant dependencies

import NavLink from "@components/ui/links/NavLink.astro";
import { useTranslations } from "@/copywriting";
import BrandLogo from "@components/BrandLogo.astro";

const copy = useTranslations();
const strings = copy.navigation;
const homeUrl = "/";
---

{/* Main header component */}
<header
  class="fixed inset-x-0 top-4 z-50 flex w-full flex-wrap text-sm md:flex-nowrap md:justify-center"
>
  {/* Navigation container */}
  <nav
    id="main-nav"
    class="relative mx-auto w-[calc(100%-2rem)] rounded-[10px] border border-[#e8e8e8]/50 bg-white/75 backdrop-blur-xl px-4 py-4 transition-all duration-200 ease-in-out md:flex md:max-w-4xl md:items-center md:justify-between md:px-6 md:py-3 lg:px-8 hover:shadow-[0_4px_24px_rgba(0,0,0,0.06)]"
    aria-label="Global"
  >
    <div class="flex items-center justify-between">
      {/* Brand logo */}
      <a
        class="flex-none rounded-lg text-xl font-bold ring-zinc-500 outline-hidden focus-visible:ring-3 dark:ring-zinc-200 dark:focus:outline-hidden"
        href={homeUrl}
        aria-label="Brand"
      >
        <BrandLogo class="h-auto w-auto" />
      </a>
      {/* Mobile CTA & Collapse toggle */}
      <div class="flex items-center gap-x-2 mr-5 ml-auto md:hidden">
        {
          strings.navBarLinks.map((link) => {
            if (link.url === "#audit") {
              return (
                <div
                  class="nav-cta-wrapper grid grid-cols-[0fr] items-center opacity-0 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] data-[visible=true]:grid-cols-[1fr] data-[visible=true]:opacity-100 pointer-events-none data-[visible=true]:pointer-events-auto"
                  data-visible="false"
                >
                  <div class="overflow-hidden">
                    <a
                      href={link.url}
                      class="nav-cta-button group inline-flex w-full items-center justify-center gap-x-[6px] rounded-[8px] bg-[#0f0f0f] px-[16px] py-[8px] text-[13px] font-medium text-white outline-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:bg-[#2a2a2a] active:scale-[0.98] whitespace-nowrap scale-95 opacity-0 data-[visible=true]:scale-100 data-[visible=true]:opacity-100"
                      data-visible="false"
                    >
                      {link.name}
                    </a>
                  </div>
                </div>
              );
            }
          })
        }
        <button
          type="button"
          class="hs-collapse-toggle text-brand-text hover:bg-brand-accent-1/20 flex h-8 w-8 items-center justify-center rounded-full text-sm font-bold transition duration-300 disabled:pointer-events-none disabled:opacity-50 dark:focus:outline-hidden"
          data-hs-collapse="#navbar-collapse-with-animation"
          aria-controls="navbar-collapse-with-animation"
          aria-label="Toggle navigation"
        >
          <svg
            class="hs-collapse-open:hidden h-[1.25rem] w-[1.25rem] shrink-0"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="3" x2="21" y1="6" y2="6"></line>
            <line x1="3" x2="21" y1="12" y2="12"></line>
            <line x1="3" x2="21" y1="18" y2="18"></line>
          </svg>
          <svg
            class="hs-collapse-open:block hidden h-[1.25rem] w-[1.25rem] shrink-0"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
          </svg>
        </button>
      </div>
    </div>
    {/* Contains navigation links */}
    <div
      id="navbar-collapse-with-animation"
      class="hs-collapse hidden grow basis-full overflow-hidden transition-all duration-300 md:block md:overflow-visible"
    >
      {/* Navigation links container */}
      <div
        class="mt-5 flex flex-col md:mt-0 md:flex-row md:items-center md:justify-end md:ps-7"
      >
        <div class="flex flex-col gap-y-4 md:flex-row md:items-center md:gap-x-4 md:gap-y-0 lg:gap-x-7">
          {
            strings.navBarLinks.map((link) => {
              if (link.url !== "#audit") {
                return <NavLink url={link.url} name={link.name} />;
              }
            })
          }
        </div>

        {
          strings.navBarLinks.map((link) => {
            if (link.url === "#audit") {
              return (
                <div
                  class="nav-cta-wrapper hidden md:grid grid-cols-[0fr] items-center opacity-0 transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] md:mt-0 data-[visible=true]:grid-cols-[1fr] data-[visible=true]:opacity-100 md:data-[visible=true]:ml-4 lg:data-[visible=true]:ml-7 pointer-events-none data-[visible=true]:pointer-events-auto"
                  data-visible="false"
                >
                  <div class="overflow-hidden">
                    <a
                      href={link.url}
                      class="nav-cta-button group inline-flex w-full items-center justify-center gap-x-[8px] rounded-[8px] bg-[#0f0f0f] px-[24px] py-[12px] text-[14px] font-medium text-white outline-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] hover:bg-[#2a2a2a] active:scale-[0.98] whitespace-nowrap md:w-auto scale-95 opacity-0 data-[visible=true]:scale-100 data-[visible=true]:opacity-100"
                      data-visible="false"
                    >
                      {link.name}
                    </a>
                  </div>
                </div>
              );
            }
          })
        }
      </div>
    </div>
  </nav>
</header>

<div id="nav-sentinel" class="pointer-events-none absolute top-0 h-px w-full">
</div>

<script>
  let navbarObserver: IntersectionObserver | undefined;

  function initNavbar() {
    const nav = document.getElementById("main-nav");
    const sentinel = document.getElementById("hero-buttons-container") || document.getElementById("hero-wrap") || document.getElementById("nav-sentinel");
    const ctaWrappers = document.querySelectorAll(".nav-cta-wrapper");
    const ctaBtns = document.querySelectorAll(".nav-cta-button");

    if (nav && sentinel) {
      if (navbarObserver) {
        navbarObserver.disconnect();
      }

      navbarObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) {
              // Scrolled down
              nav.classList.add("md:max-w-6xl");
              nav.classList.remove("md:max-w-4xl");
              ctaWrappers.forEach((el) => { (el as HTMLElement).dataset.visible = "true"; });
              ctaBtns.forEach((el) => { (el as HTMLElement).dataset.visible = "true"; });
            } else {
              // At the top
              nav.classList.remove("md:max-w-6xl");
              nav.classList.add("md:max-w-4xl");
              ctaWrappers.forEach((el) => { (el as HTMLElement).dataset.visible = "false"; });
              ctaBtns.forEach((el) => { (el as HTMLElement).dataset.visible = "false"; });
            }
          });
        },
        {
          rootMargin: "0px",
          threshold: 0,
        },
      );

      navbarObserver.observe(sentinel);
    }
  }

  // Initial setup
  initNavbar();

  // Custom smooth scroll
  function initSmoothScroll() {
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.removeEventListener("click", handleAnchorClick);
      anchor.addEventListener("click", handleAnchorClick);
    });
  }

  function handleAnchorClick(this: HTMLAnchorElement, e: Event) {
    const hash = this.getAttribute("href");
    if (!hash || hash === "#") return;

    const targetEl = document.querySelector(hash);
    if (targetEl) {
      e.preventDefault();
      const headerOffset = 0;
      const elementPosition = targetEl.getBoundingClientRect().top;
      const offsetPosition = elementPosition + window.scrollY - headerOffset;

      window.scrollTo({
        top: offsetPosition,
        behavior: "smooth",
      });

      history.pushState(null, "", hash);
    }
  }

  initSmoothScroll();

  document.addEventListener("astro:page-load", () => {
    initNavbar();
    initSmoothScroll();
  });
</script>

