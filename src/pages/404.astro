---
// Import section components
import MainLayout from '@/layouts/MainLayout.astro';
import Btn404 from '@components/ui/buttons/Btn404.astro';
import { useTranslations } from '@/copywriting';

// Determine language from the URL
const urlPath = Astro.url.pathname;
const langCodeMatch = urlPath.match(/^\/(en|fr)\//);
const lang = langCodeMatch ? langCodeMatch[1] : 'en';

const copy = useTranslations(lang);
const { pageTitle, subTitle, content, btnTitle } = copy.pages.fourOhFour;
---

<MainLayout title={pageTitle}>
  <section class="grid h-svh place-content-center">
    <div class="mx-auto max-w-(--breakpoint-xl) px-4 py-8 lg:px-6 lg:py-16">
      <div class="mx-auto max-w-(--breakpoint-sm) text-center">
        <h1
          class="text-dark text-brand-accent-1 dark:text-brand-accent-1/90 mb-4 text-7xl font-extrabold lg:text-9xl"
        >
          404
        </h1>
        <p
          id="subtitle"
          class="text-brand-text/80 dark:text-brand-text/90 mb-4 text-3xl font-bold tracking-tight text-balance md:text-4xl"
        >
          {subTitle}
        </p>
        <p
          id="content"
          class="text-brand-text/70 dark:text-brand-text/60 mb-4 text-lg text-pretty"
        >
          {content}
        </p>
        {/* Display a button that navigates user back to the previous page */}
        <Btn404 title={btnTitle} id="go-back" />
      </div>
    </div>
  </section>
</MainLayout>

{/* JavaScript code to handle going back to the previous page */}
<script>
  const goBackButton = document.getElementById('go-back') as HTMLButtonElement;

  goBackButton.addEventListener('click', () => {
    history.back();
  });
</script>
