---
// Extract the properties from Astro.props
const { title, subTitle } = Astro.props;
// Define TypeScript interface for the properties
interface Props {
  title: string;
  subTitle: string;
}
---

{/* Container for title and subtitle */}
<div>
  <p class="text-brand-accent-1 dark:text-brand-accent-1/90 text-3xl font-bold">
    {title}
  </p>
  <p class="text-brand-text/70 dark:text-brand-text/60 mt-1">{subTitle}</p>
</div>
