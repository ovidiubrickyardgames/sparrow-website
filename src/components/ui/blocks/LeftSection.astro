---
// Import the necessary modules
import { Image } from 'astro:assets';
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';
// Destructure the props passed to the Astro component
const { title, subTitle, btnExists, btnTitle, btnURL, img, imgAlt } =
  Astro.props;
// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  img: any;
  imgAlt: any;
}
---

{/* The root section of the component */}
<section
  class="content-container items-center gap-8 py-10 sm:py-16 md:grid md:grid-cols-2 lg:grid lg:grid-cols-2 lg:py-14 xl:gap-16"
>
  {/* The Image component which renders the image */}
  <Image
    class="w-full rounded-xl"
    src={img}
    alt={imgAlt}
    draggable={'false'}
    format={'avif'}
  />
  {/* The container for title, subtitle, and optional CTA button */}
  <div class="mt-4 md:mt-0">
    {/* The title of the section */}
    <h2
      class="text-brand-text dark:text-brand-text/90 mb-4 text-4xl font-extrabold tracking-tight text-balance"
    >
      {title}
    </h2>
    {/* The subtitle of the section */}
    <p
      class="text-brand-text/70 dark:text-brand-text/60 mb-4 max-w-prose font-normal text-pretty sm:text-lg"
    >
      {subTitle}
    </p>
    {/* Conditionally render the Primary CTA button if btnExists is true */}
    {btnExists ? <PrimaryCTA title={btnTitle} url={btnURL} /> : null}
  </div>
</section>
