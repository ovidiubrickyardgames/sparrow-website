---
// Import the necessary dependencies
import FooterSocialLink from '@components/ui/links/FooterSocialLink.astro';

import { useTranslations } from '@/copywriting';
import Icon from '@components/ui/icons/Icon.astro';
import BrandLogo from '@components/BrandLogo.astro';

// Select the correct translation based on the page's lang prop:
const pathParts = Astro.url.pathname.split('/');
const currentLocale = ['fr', 'ro', 'de'].includes(pathParts[1])
  ? pathParts[1]
  : Astro.currentLocale || 'en';
const copy = useTranslations(currentLocale);
const SITE = copy.site;
const strings = copy.navigation;

const crafted: string = strings.craftedBy;
---

<footer class="bg-brand-primary/10 border-brand-accent-1/10 w-full border-t">
  <div
    class="mx-auto w-full max-w-[85rem] px-4 py-10 sm:px-6 lg:px-16 lg:pt-20 2xl:max-w-(--breakpoint-2xl)"
  >
    <div class="grid grid-cols-2 gap-6 md:grid-cols-3 lg:grid-cols-3">
      <div class="col-span-full md:col-span-1">
        {/* Brand Logo */}
        <BrandLogo class="h-auto w-32" />
      </div>
      {/* An array of links for Product and Company sections */}
      {
        strings.footerLinks.map(section => (
          <div class="col-span-1">
            <h3 class="text-brand-text font-bold">{section.section}</h3>
            <ul class="mt-3 grid space-y-3">
              {section.links.map((link, index) => (
                <li>
                  <a
                    href={link.url}
                    data-astro-prefetch
                    class="text-brand-text/70 hover:text-brand-accent-1 inline-flex gap-x-2 rounded-lg ring-zinc-500 outline-hidden transition-[color,background-color,border-color,box-shadow] duration-150 focus-visible:ring-3 dark:ring-zinc-200 dark:focus:outline-hidden"
                  >
                    {link.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div
      class="mt-9 grid gap-y-2 sm:mt-12 sm:flex sm:items-center sm:justify-between sm:gap-y-0"
    >
      <div class="flex items-center justify-between">
        <p class="text-brand-text/70 dark:text-brand-text/60 text-sm">
          © <span id="current-year">2026</span> {SITE.title}. {strings.allRightsReserved}
        </p>
      </div>

      {/* Social Brands */}
      {
        /* <div>
        <FooterSocialLink url={strings.socialLinks.facebook}
          ><Icon name="facebookFooter" />
        </FooterSocialLink>

        <FooterSocialLink url={strings.socialLinks.x}
          ><Icon name="xFooter" /></FooterSocialLink
        >

        <FooterSocialLink url={strings.socialLinks.github}
          ><Icon name="githubFooter" />
        </FooterSocialLink>

        <FooterSocialLink url={strings.socialLinks.google}
          ><Icon name="googleFooter" />
        </FooterSocialLink>

        <FooterSocialLink url={strings.socialLinks.slack}
          ><Icon name="slackFooter" />
        </FooterSocialLink>
      </div> */
      }
    </div>

    <script>
      const year = new Date().getFullYear();
      const element = document.getElementById('current-year');
      if (element) {
        element.innerText = year.toString();
      }
    </script>
  </div>
</footer>
