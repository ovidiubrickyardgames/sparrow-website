          </div>
        </div>

        {/* Floating Deal Cards */}
        <div class="absolute -right-2 sm:-right-4 lg:-right-6 xl:-right-8 top-1/4 h-16 w-44 rounded-xl border border-zinc-200/80 bg-white/95 shadow-[0_15px_35px_rgba(0,0,0,0.08)] backdrop-blur-md p-3 flex items-center gap-3 floating-card-1 z-30 hidden sm:flex transform hover:scale-105 transition-transform">
          <div class="h-10 w-10 rounded-full bg-emerald-50 flex items-center justify-center border border-emerald-100 shrink-0">
            <svg class="w-5 h-5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div class="flex flex-col gap-0.5 flex-1">
            <div class="text-[11px] font-bold text-zinc-800">Meeting Booked</div>
            <div class="text-[10px] text-zinc-500">$45,000 Pipeline</div>
          </div>
        </div>

        <div class="absolute -left-4 sm:-left-12 bottom-1/4 h-20 w-52 rounded-xl border border-zinc-200/80 bg-white/95 shadow-[0_20px_40px_rgba(0,0,0,0.1)] backdrop-blur-md p-3.5 hidden sm:flex flex-col justify-center gap-2.5 floating-card-2 z-30 transform hover:scale-105 transition-transform">
          <div class="flex justify-between items-center w-full">
            <div class="text-[11px] font-bold text-zinc-800">Warm Lead</div>
            <div class="h-4 px-2 rounded-full bg-zinc-100 border border-zinc-200 flex items-center justify-center text-[8px] font-bold text-zinc-500 uppercase tracking-wide">
               Ready
            </div>
          </div>
          <div class="flex items-center gap-2.5 mt-0.5">
