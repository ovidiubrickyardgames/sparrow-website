---
import MainLayout from '@/layouts/MainLayout.astro';
import ContactSection from '@components/sections/misc/ContactSection.astro';
import { useTranslations } from '@/copywriting';

const copy = useTranslations();
const pageCopy = copy.pages.home;

const pageTitle = pageCopy.metaTitle || 'Sparrow | Outbound Sales Partnership';
const metaDescription = pageCopy.metaDescription || 'We Build, Manage, and Close Your B2B Pipeline.';
---

<MainLayout title={pageTitle} customDescription={metaDescription}>
  {/* Core Container */}
  <div
    class="outbound-page-wrapper relative min-h-screen overflow-hidden bg-white text-zinc-800"
  >
    {/* Ambient Organic Glow Backgrounds */}
    <div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div class="dot-grid absolute inset-0 opacity-[0.04] bg-[radial-gradient(#2563eb_1px,transparent_1px)] bg-[size:24px_24px]"></div>
      <div class="absolute -top-[10%] -left-[10%] h-[600px] w-[600px] rounded-full bg-blue-400/5 blur-[150px]"></div>
      <div class="absolute top-[20%] right-[-10%] h-[500px] w-[500px] rounded-full bg-sky-400/5 blur-[130px]"></div>
      <div class="absolute top-[50%] left-[10%] h-[700px] w-[700px] rounded-full bg-blue-500/5 blur-[160px]"></div>
      <div class="absolute -bottom-[10%] right-[10%] h-[600px] w-[600px] rounded-full bg-sky-500/5 blur-[150px]"></div>
    </div>

    {/* Hero Section */}
    <div class="relative z-10 flex min-h-[92vh] items-center pt-24 lg:pt-0">
      

      <div class="content-container relative z-10 w-full py-20 lg:py-32">
        <div class="grid grid-cols-1 items-center gap-12 lg:grid-cols-12">
          <div class="flex max-w-2xl flex-col items-start text-left lg:col-span-7">
            <div class="reveal-element mb-6 flex items-center gap-2">
              <span class="font-serif text-lg italic text-blue-600">{pageCopy.hero.eyebrowLabel}</span>
              <span class="h-px w-8 bg-zinc-300"></span>
            </div>

            <h1 class="reveal-heading font-display mb-6 text-4xl leading-[1.08] font-bold tracking-tight text-zinc-950 sm:text-6xl">
              <Fragment set:html={pageCopy.hero.titleHtml} />
            </h1>

            <p class="reveal-element mb-10 max-w-xl text-lg leading-relaxed font-light text-zinc-600 sm:text-xl">
              {pageCopy.hero.subTitle}
            </p>

            <div class="reveal-element flex w-full flex-col gap-4 sm:w-auto sm:flex-row">
              <a href={pageCopy.hero.primaryBtnURL} class="group inline-flex items-center justify-center gap-x-2 rounded-lg px-5 py-3 text-sm font-bold ring-zinc-500 transition duration-300 focus-visible:ring-3 outline-hidden bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white shadow-[0_4px_16px_0_rgba(37,99,235,0.25)] hover:shadow-[0_6px_24px_0_rgba(37,99,235,0.45)] 2xl:text-base font-mono tracking-wider uppercase text-xs">
                {pageCopy.hero.primaryBtn}
                <svg class="h-4 w-4 shrink-0 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>

    {/* Section 2: Agitation */}
    <section id="approach" class="relative z-10 border-y border-zinc-200 bg-zinc-50/50 py-24 backdrop-blur-sm lg:py-32">
      <div class="pointer-events-none absolute top-1/2 left-1/2 h-[250px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-blue-400/5 blur-[120px]"></div>

      <div class="content-container relative z-10">
        <div class="mx-auto max-w-4xl">
          <div class="reveal-element mb-8 flex justify-center">
            <div class="flex h-12 w-12 items-center justify-center rounded-full border border-blue-200 bg-blue-50 shadow-[0_0_20px_rgba(59,130,246,0.05)]">
              <div class="h-2 w-2 rounded-full bg-sky-500"></div>
            </div>
          </div>

          <h2 class="reveal-heading font-display mb-8 text-center text-3xl leading-tight font-bold tracking-tight text-zinc-950 sm:text-5xl">
            <Fragment set:html={pageCopy.agitation.titleHtml} />
          </h2>

          <div class="reveal-element mx-auto mb-10 h-[1px] w-24 bg-gradient-to-r from-transparent via-sky-500/40 to-transparent"></div>

          <p class="reveal-element mx-auto mb-12 max-w-3xl text-center text-lg leading-relaxed font-light text-zinc-600 sm:text-xl">
            {pageCopy.agitation.subTitle}
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {pageCopy.agitation.stats.map(stat => (
              <div class="premium-card p-6 text-center">
                <div class="text-4xl font-bold text-blue-600 mb-2">{stat.stat}</div>
                <p class="text-zinc-600 font-medium">{stat.description}</p>
              </div>
            ))}
          </div>

          <p class="reveal-element mx-auto mt-12 max-w-3xl text-center text-lg font-medium text-zinc-800">
            {pageCopy.agitation.conclusion}
          </p>
        </div>
      </div>
    </section>

    {/* Section 3: Solution (Hybrid Model) */}
    <section class="relative z-10 bg-transparent py-20 lg:py-28 border-b border-zinc-200">
      <div class="content-container">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl">
            <Fragment set:html={pageCopy.solution.titleHtml} />
          </h2>
          <p class="reveal-element text-lg font-light text-zinc-600 whitespace-pre-line">
            {pageCopy.solution.subTitle}
          </p>
        </div>

        <div class="reveal-grid mx-auto grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-3">
          {pageCopy.solution.items.map((item, idx) => (
             <div class="premium-card group relative p-8">
                <h3 class="font-display mb-4 text-xl font-bold text-zinc-900 group-hover:text-sky-600 transition-colors duration-300">
                  {item.title}
                </h3>
                <p class="text-base leading-relaxed text-zinc-600">
                  {item.content}
                </p>
             </div>
          ))}
        </div>
      </div>
    </section>

    {/* Section 4: Process */}
    <section id="capabilities" class="relative z-10 scroll-mt-24 py-24 lg:py-36 bg-zinc-50/50">
      <div class="content-container">
        <div class="mx-auto mb-20 max-w-3xl text-center">
          <h2 class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl">
            <Fragment set:html={pageCopy.process.titleHtml} />
          </h2>
          <p class="reveal-element text-lg font-light text-zinc-600">
            {pageCopy.process.subTitle}
          </p>
        </div>

        <div class="reveal-grid relative grid grid-cols-1 gap-8 md:grid-cols-3">
          {pageCopy.process.phases.map((phase, idx) => (
            <div class="premium-card group relative z-10 p-8">
              <div class={`mb-8 flex h-12 w-12 items-center justify-center rounded-xl border transition-transform duration-500 group-hover:scale-110 ${idx % 2 === 0 ? 'border-blue-500/20 bg-blue-500/5 group-hover:border-blue-500 text-blue-600' : 'border-sky-500/20 bg-sky-500/5 group-hover:border-sky-500 text-sky-600'}`}>
                <span class="font-bold text-lg">{idx + 1}</span>
              </div>
              <h3 class={`font-display mb-4 text-2xl font-bold text-zinc-900 transition-colors duration-300 ${idx % 2 === 0 ? 'group-hover:text-blue-600' : 'group-hover:text-sky-600'}`}>
                {phase.title}
              </h3>
              <p class="text-base leading-relaxed text-zinc-600">
                {phase.content}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* Section 5: Analytics */}
    <section class="relative z-10 bg-transparent py-20 lg:py-28 border-b border-zinc-200">
      <div class="content-container">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2 class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl">
            <Fragment set:html={pageCopy.analytics.titleHtml} />
          </h2>
          <p class="reveal-element text-lg font-light text-zinc-600 whitespace-pre-line">
            {pageCopy.analytics.subTitle}
          </p>
        </div>

        <div class="reveal-grid mx-auto grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-3">
          {pageCopy.analytics.items.map((item, idx) => (
             <div class="premium-card group relative p-8 text-center border-t-4 border-t-transparent hover:border-t-blue-500 transition-all">
                <h3 class="font-display mb-4 text-xl font-bold text-zinc-900 group-hover:text-blue-600 transition-colors duration-300">
                  {item.title}
                </h3>
                <p class="text-base leading-relaxed text-zinc-600">
                  {item.content}
                </p>
             </div>
          ))}
        </div>
      </div>
    </section>

    {/* Section 6: Pricing */}
    <section id="pricing" class="relative z-10 scroll-mt-24 border-t border-zinc-200 bg-zinc-50/50 py-24 lg:py-36">
      <div class="pointer-events-none absolute right-0 bottom-0 h-[400px] w-[400px] rounded-full bg-sky-400/5 blur-[120px]"></div>

      <div class="content-container relative z-10">
        <div class="mx-auto mb-20 max-w-2xl text-center">
          <h2 class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl">
            <Fragment set:html={pageCopy.pricing.titleHtml} />
          </h2>
          <p class="reveal-element text-lg leading-relaxed font-light text-zinc-600">
            {pageCopy.pricing.subTitle}
          </p>
        </div>

        <div class="reveal-grid mx-auto grid max-w-6xl grid-cols-1 items-stretch gap-8 lg:grid-cols-3">
          {/* Starter */}
          <div class="premium-card group relative flex flex-col justify-between p-8">
            <div>
              <div class="mb-8">
                <h3 class="font-display mb-2 text-2xl font-bold text-zinc-900">{pageCopy.pricing.plans.starter.title}</h3>
                <p class="text-sm text-zinc-500 mb-4 h-10">{pageCopy.pricing.plans.starter.description}</p>
                <div class="text-3xl font-bold text-blue-600">{pageCopy.pricing.plans.starter.price}</div>
              </div>
              <div class="my-6 h-[1px] w-full bg-zinc-200"></div>
              <ul class="mb-10 space-y-4 text-sm text-zinc-700">
                {pageCopy.pricing.plans.starter.features.map(f => (
                  <li class="flex items-start gap-3"><svg class="mt-1 h-4 w-4 shrink-0 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{f}</li>
                ))}
              </ul>
            </div>
            <a href="#audit" class="mt-8 w-full inline-flex items-center justify-center gap-x-2 rounded-lg border border-zinc-300 bg-white px-4 py-3 text-center text-xs font-mono font-medium uppercase tracking-wider text-zinc-700 shadow-xs transition duration-300 hover:bg-blue-50 hover:text-blue-700 hover:border-blue-500/40 active:bg-blue-100 outline-hidden ring-zinc-500 focus-visible:ring-3">
              Get Started
            </a>
          </div>

          {/* Growth */}
          <div class="premium-card group relative flex flex-col justify-between p-8 border-sky-500/30 shadow-[0_0_30px_rgba(14,165,233,0.1)]">
            <div class="absolute -top-[14px] left-1/2 -translate-x-1/2 rounded-full bg-gradient-to-r from-blue-600 to-sky-500 px-4 py-1 font-mono text-[9px] font-bold tracking-widest text-white uppercase shadow-[0_4px_12px_rgba(37,99,235,0.15)] z-20">
              {pageCopy.pricing.plans.growth.badge}
            </div>
            <div>
              <div class="mb-8">
                <h3 class="font-display mb-2 text-2xl font-bold text-zinc-900">{pageCopy.pricing.plans.growth.title}</h3>
                <p class="text-sm text-zinc-500 mb-4 h-10">{pageCopy.pricing.plans.growth.description}</p>
                <div class="text-3xl font-bold text-sky-600">{pageCopy.pricing.plans.growth.price}</div>
              </div>
              <div class="my-6 h-[1px] w-full bg-zinc-200"></div>
              <ul class="mb-10 space-y-4 text-sm text-zinc-700">
                {pageCopy.pricing.plans.growth.features.map(f => (
                  <li class="flex items-start gap-3"><svg class="mt-1 h-4 w-4 shrink-0 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{f}</li>
                ))}
              </ul>
            </div>
            <a href="#audit" class="mt-8 w-full inline-flex items-center justify-center gap-x-2 rounded-lg bg-sky-500 px-4 py-3 text-center text-xs font-mono font-bold uppercase tracking-wider text-zinc-950 shadow-[0_4px_12px_rgba(14,165,233,0.25)] transition duration-300 hover:bg-sky-600 hover:shadow-[0_6px_20px_rgba(14,165,233,0.35)] outline-hidden ring-zinc-500 focus-visible:ring-3">
              Get Started
            </a>
          </div>

          {/* Scale */}
          <div class="premium-card group relative flex flex-col justify-between p-8">
            <div>
              <div class="mb-8">
                <h3 class="font-display mb-2 text-2xl font-bold text-zinc-900">{pageCopy.pricing.plans.scale.title}</h3>
                <p class="text-sm text-zinc-500 mb-4 h-10">{pageCopy.pricing.plans.scale.description}</p>
                <div class="text-3xl font-bold text-blue-600">{pageCopy.pricing.plans.scale.price}</div>
              </div>
              <div class="my-6 h-[1px] w-full bg-zinc-200"></div>
              <ul class="mb-10 space-y-4 text-sm text-zinc-700">
                {pageCopy.pricing.plans.scale.features.map(f => (
                  <li class="flex items-start gap-3"><svg class="mt-1 h-4 w-4 shrink-0 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"></path></svg>{f}</li>
                ))}
              </ul>
            </div>
            <a href="#audit" class="mt-8 w-full inline-flex items-center justify-center gap-x-2 rounded-lg border border-zinc-300 bg-white px-4 py-3 text-center text-xs font-mono font-medium uppercase tracking-wider text-zinc-700 shadow-xs transition duration-300 hover:bg-blue-50 hover:text-blue-700 hover:border-blue-500/40 active:bg-blue-100 outline-hidden ring-zinc-500 focus-visible:ring-3">
              Get Started
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Section 7: Final CTA & Contact */}
    <section id="audit" class="relative z-10 bg-white py-24 lg:py-36">
      <div class="content-container">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <h2 class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl">
            <Fragment set:html={pageCopy.cta.titleHtml} />
          </h2>
          <p class="reveal-element text-lg font-light text-zinc-600 whitespace-pre-line">
            {pageCopy.cta.subTitle}
          </p>
        </div>
        
        {/* Contact Form Container (hidden title from contact section for seamless integration) */}
        <div class="hide-contact-title">
           <ContactSection />
        </div>
      </div>
    </section>

  </div>
</MainLayout>

<style is:global>
  /* Premium Card Styles */
  .premium-card {
    border-radius: 1rem;
    border: 1px solid #e5e7eb;
    background: rgba(250, 250, 250, 0.5);
    transition: all 0.3s ease-in-out;
  }
  .premium-card:hover {
    background: white;
    border-color: rgba(37, 99, 235, 0.2);
    box-shadow: 0 10px 40px -10px rgba(0,0,0,0.08);
  }
  
  /* Utility to hide Contact Section's native title to avoid redundancy with the CTA */
  .hide-contact-title h1, .hide-contact-title p.text-pretty {
    display: none !important;
  }
</style>
