---
// Import SecondaryCTA component for use in this module
import SecondaryCTA from '@components/ui/buttons/SecondaryCTA.astro';
import Icon from '@components/ui/icons/Icon.astro';

// Define props from Astro
const { pricing } = Astro.props;

// Define TypeScript type for products.
type Product = {
  name: string;
  description: string;
  price: string;
  cents: string;
  billingFrequency: string;
  features: Array<string>;
  purchaseBtnTitle: string;
  purchaseLink: string;
};

interface PricingSectionProps {
  title: string;
  subTitle: string;
  badge: string;
  thirdOption: string;
  btnText: string;
  pricing: {
    title: string;
    subTitle: string;
    starterKit: Product;
    professionalToolbox: Product;
  };
}
---

<section
  class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14 2xl:max-w-full"
>
  {/* Section heading and sub-heading */}
  <div class="mx-auto mb-10 max-w-2xl text-center lg:mb-14">
    <h2
      class="text-brand-text dark:text-brand-text/90 text-2xl font-bold tracking-tight text-balance md:text-4xl md:leading-tight"
    >
      {pricing.title}
    </h2>
    <p class="text-brand-text/70 dark:text-brand-text/60 mt-1 text-pretty">
      {pricing.subTitle}
    </p>
  </div>
  {/* Contains two main product blocks */}
  <div class="flex flex-wrap items-center justify-center gap-4 sm:gap-0">
    {/* Starter Kit product details */}
    <div
      class="w-full rounded-xl border border-[#e8e8e8] px-8 py-10 sm:w-1/2 sm:rounded-r-none sm:px-10 sm:py-12 lg:w-1/3"
    >
      <div class="mb-4">
        <h3 class="text-[#111] dark:text-white text-2xl font-bold sm:text-3xl">
          {pricing.starterKit.name}
        </h3>
        <p class="text-gray-500">{pricing.starterKit.description}</p>
      </div>

      <div class="mb-4">
        <span class="text-[#111] dark:text-white text-4xl font-medium"
          >{pricing.starterKit.price}</span
        >
        <span class="text-[#111]/80 dark:text-white/80 text-lg font-medium"
          >{pricing.starterKit.cents}</span
        >
        <span class="text-gray-500 ms-3 text-sm"
          >{pricing.starterKit.billingFrequency}</span
        >
      </div>
      {
        /* Features list - automatically created by mapping over `features` array */
      }
      <ul class="text-[#111]/80 dark:text-white/80 mb-6 mt-8 space-y-2">
        {
          pricing.starterKit.features.map((feature: string) => (
            <li class="flex items-center gap-2">
              <span class="text-[#555] dark:text-gray-400">—</span>
              <span>{feature}</span>
            </li>
          ))
        }
      </ul>
      {/* CTA for purchasing the product */}
      <a
        href={pricing.starterKit.purchaseLink}
        data-astro-prefetch
        class="group inline-flex w-full items-center justify-center gap-x-[8px] rounded-[8px] bg-[#0f0f0f] px-[24px] py-[12px] text-[14px] font-medium text-white transition-colors duration-150 ease-out outline-hidden hover:bg-[#2a2a2a] active:scale-[0.98]"
        >{pricing.starterKit.purchaseBtnTitle}</a
      >
    </div>
    {/* Professional Toolbox product details */}
    <div
      class="w-full rounded-xl bg-[#0f0f0f] px-8 py-10 sm:w-1/2 sm:px-10 sm:py-12"
    >
      <div
        class="mb-4 flex flex-col items-start justify-between gap-4 lg:flex-row"
      >
        <div>
          <h3 class="text-white text-2xl font-bold sm:text-3xl">
            {pricing.professionalToolbox.name}
          </h3>
          <p class="text-white/70">
            {pricing.professionalToolbox.description}
          </p>
        </div>

        <span
          class="bg-white/10 text-white order-first inline-block rounded-full px-3 py-1 text-center text-xs font-bold tracking-wider uppercase lg:order-none"
          >{pricing.badge}</span
        >
      </div>

      <div class="mb-4">
        <span class="text-white text-6xl font-medium"
          >{pricing.professionalToolbox.price}</span
        >
        <span class="text-white/60 text-lg font-medium"
          >{pricing.professionalToolbox.cents}</span
        >
        <span class="text-white/60 ms-3"
          >{pricing.professionalToolbox.billingFrequency}</span
        >
      </div>
      {
        /* Features list - automatically created by mapping over `features` array */
      }
      <ul class="text-white/80 mb-6 mt-8 space-y-2">
        {
          pricing.professionalToolbox.features.map((feature: string) => (
            <li class="flex items-center gap-2">
              <span class="text-[#888]">—</span>
              <span>{feature}</span>
            </li>
          ))
        }
      </ul>
      {/* CTA for purchasing the product */}
      <a
        href={pricing.professionalToolbox.purchaseLink}
        data-astro-prefetch
        class="group inline-flex w-full items-center justify-center gap-x-[8px] rounded-[8px] border border-[rgba(255,255,255,0.3)] bg-white px-[24px] py-[12px] text-[14px] font-medium text-[#0f0f0f] transition-colors duration-150 ease-out outline-hidden active:scale-[0.98]"
        >{pricing.professionalToolbox.purchaseBtnTitle}</a
      >
    </div>
  </div>
  {/* Call to action for Enterprise Solutions */}
  <div class="mt-8 flex items-center justify-center gap-x-3 md:mt-12">
    <p class="text-brand-text/70 dark:text-brand-text/60 text-sm">
      {pricing.thirdOption}
    </p>

    <SecondaryCTA title={pricing.btnText} url="#" />
  </div>
</section>
