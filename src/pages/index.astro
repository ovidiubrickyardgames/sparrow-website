---
import MainLayout from "@/layouts/MainLayout.astro";
import ContactSection from "@components/sections/misc/ContactSection.astro";
import ProcessCard from "@components/ui/cards/ProcessCard.astro";
import { useTranslations } from "@/copywriting";

const copy = useTranslations();
const pageCopy = copy.pages.home;

const pageTitle = pageCopy.metaTitle || "Sparrow | Outbound Sales Partnership";
const metaDescription =
  pageCopy.metaDescription || "We Build, Manage, and Close Your B2B Pipeline.";
---

<MainLayout title={pageTitle} customDescription={metaDescription}>
  {/* Core Container */}
  <div
    class="outbound-page-wrapper relative min-h-screen overflow-hidden bg-[#f7f7f5] text-zinc-800"
  >
    {/* Ambient Organic Glow Backgrounds */}
    <div class="pointer-events-none absolute inset-0 z-0 overflow-hidden">
      <div
        class="dot-grid absolute inset-0 opacity-[0.04] bg-[radial-gradient(#999_1px,transparent_1px)] bg-[size:24px_24px]"
      >
      </div>
    </div>

    {/* Hero Section */}
    <div
      class="relative z-10 flex min-h-[92vh] items-center pt-24 lg:pt-0 overflow-hidden"
      id="hero-wrap"
    >
      <canvas
        id="c"
        class="absolute inset-0 w-full h-full pointer-events-none -z-10"
        style="mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, transparent 35%, black 80%); -webkit-mask-image: radial-gradient(ellipse 60% 60% at 50% 50%, transparent 35%, black 80%);"
      ></canvas>

      <div
        class="content-container relative z-10 w-full py-20 lg:py-32 flex flex-col items-center justify-center"
      >
        <div class="flex max-w-5xl flex-col items-center text-center">
          <div class="reveal-element mb-6 flex items-center justify-center">
            <span class="text-[11px] tracking-[0.12em] text-[#999] uppercase"
              >{pageCopy.hero.eyebrowLabel}</span
            >
          </div>

          <h1
            class="reveal-heading font-display mb-6 text-5xl leading-[1.08] font-bold tracking-[-0.02em] text-zinc-950 sm:text-7xl text-center"
          >
            <Fragment set:html={pageCopy.hero.titleHtml} />
          </h1>

          <p
            class="reveal-element mx-auto mb-10 max-w-[520px] text-center text-lg leading-relaxed font-light text-[#444444] sm:text-xl"
          >
            {pageCopy.hero.subTitle}
          </p>

          <div class="reveal-element flex flex-col items-center justify-center gap-3">
            <div class="flex w-full flex-col gap-4 sm:w-auto sm:flex-row justify-center">
              <a
                href={pageCopy.hero.primaryBtnURL}
                class="group inline-flex items-center justify-center gap-x-2 rounded-[6px] px-5 py-3 text-sm font-medium ring-zinc-500 transition duration-300 focus-visible:ring-3 outline-hidden bg-[#0f0f0f] hover:bg-[#1a1a1a] active:bg-black text-white 2xl:text-base"
              >
                {pageCopy.hero.primaryBtn}
              </a>
            </div>
            {pageCopy.hero.primaryBtnSub && (
              <p class="text-[13px] font-medium text-zinc-500/80">
                {pageCopy.hero.primaryBtnSub}
              </p>
            )}
          </div>
        </div>
      </div>
    </div>

    {/* Body content wrapper for continuous background line */}
    <div class="relative w-full">
      {/* Thick, Curved Organic Background Line starting exactly at Section 2 */}
      <div class="pointer-events-none absolute inset-0 z-10 overflow-hidden">
        <svg 
          class="absolute inset-0 w-full h-full text-[#f2f2ef]" 
          viewBox="0 0 1000 1000" 
          preserveAspectRatio="none" 
          fill="none" 
          xmlns="http://www.w3.org/2000/svg"
        >
          <path 
            d="M200,0 C600,150 900,300 500,500 C100,700 400,850 800,1000" 
            stroke="currentColor" 
            stroke-width="80" 
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </div>

      {/* Section 2: Agitation */}
    <section id="approach" class="relative py-24 lg:py-32">
      <div class="pointer-events-none absolute inset-0 z-0 border-y border-zinc-200 bg-zinc-50/50 backdrop-blur-sm"></div>
      <div class="pointer-events-none absolute top-1/2 left-1/2 z-0 h-[250px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-accent-1/5 blur-[120px]"></div>

      <div class="content-container relative z-20">
        <div class="mx-auto max-w-4xl">
          <div class="reveal-element mb-8 flex justify-center">
            <div
              class="flex h-12 w-12 items-center justify-center rounded-full border border-brand-accent-1/20 bg-brand-accent-1/5 shadow-[0_0_20px_rgba(13,45,138,0.1)]"
            >
              <div class="h-2 w-2 rounded-full bg-brand-accent-1"></div>
            </div>
          </div>

          <h2
            class="reveal-heading font-display mb-8 text-center text-3xl leading-tight font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.agitation.titleHtml} />
          </h2>

          <div
            class="reveal-element mx-auto mb-10 h-[1px] w-24 bg-gradient-to-r from-transparent via-brand-accent-1/40 to-transparent"
          >
          </div>

          <p
            class="reveal-element mx-auto mb-12 max-w-3xl text-center text-lg leading-relaxed font-light text-zinc-600 sm:text-xl"
          >
            {pageCopy.agitation.subTitle}
          </p>

          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {
              pageCopy.agitation.stats.map((stat) => (
                <div class="premium-card flex flex-col justify-center p-8 text-center h-full">
                  <div class="mb-4 text-[36px] font-[300] leading-none text-brand-accent-1">
                    {stat.stat}
                  </div>
                  <p class="text-base leading-relaxed text-[#555555]">{stat.description}</p>
                </div>
              ))
            }
          </div>

          <p
            class="reveal-element mx-auto mt-12 max-w-3xl text-center text-lg font-medium text-zinc-800"
          >
            {pageCopy.agitation.conclusion}
          </p>
        </div>
      </div>
    </section>

    {/* Section 3: Solution (Hybrid Model) */}
    <section class="relative py-20 lg:py-28">
      <div class="pointer-events-none absolute inset-0 z-0 bg-transparent border-b border-zinc-200"></div>
      <div class="content-container relative z-20">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2
            class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.solution.titleHtml} />
          </h2>
          <p
            class="reveal-element text-lg font-light text-zinc-600 whitespace-pre-line"
          >
            {pageCopy.solution.subTitle}
          </p>
        </div>

        <div
          class="reveal-grid mx-auto grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-3"
        >
          {
            pageCopy.solution.items.map((item, idx) => (
              <ProcessCard
                index={idx + 1}
                title={item.title.replace(/^\d+\.\s*/, '')}
                content={item.content}
              />
            ))
          }
        </div>
      </div>
    </section>

    {/* Section 4: Process */}
    <section id="capabilities" class="relative py-24 lg:py-36">
      <div class="pointer-events-none absolute inset-0 z-0 bg-zinc-50/50"></div>
      <div class="content-container relative z-20">
        <div class="mx-auto mb-10 max-w-3xl text-center">
          <h2
            class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.process.titleHtml} />
          </h2>
          <p class="reveal-element text-lg font-light text-zinc-600">
            {pageCopy.process.subTitle}
          </p>
        </div>

        <div class="reveal-grid relative grid grid-cols-1 gap-8 md:grid-cols-3">
          {
            pageCopy.process.phases.map((phase, idx) => (
              <ProcessCard
                index={idx + 1}
                title={phase.title}
                content={phase.content}
              />
            ))
          }
        </div>
      </div>
    </section>

    {/* Section 5: Analytics */}
    <section class="relative py-20 lg:py-28">
      <div class="pointer-events-none absolute inset-0 z-0 bg-transparent border-b border-zinc-200"></div>
      <div class="content-container relative z-20">
        <div class="mx-auto mb-16 max-w-3xl text-center">
          <h2
            class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.analytics.titleHtml} />
          </h2>
          <p
            class="reveal-element text-lg font-light text-zinc-600 whitespace-pre-line"
          >
            {pageCopy.analytics.subTitle}
          </p>
        </div>

        <div
          class="reveal-grid mx-auto grid max-w-5xl grid-cols-1 gap-8 md:grid-cols-3"
        >
          {
            pageCopy.analytics.items.map((item, idx) => (
              <ProcessCard
                title={item.title}
                content={item.content}
              />
            ))
          }
        </div>
      </div>
    </section>

    {/* Section 6: Pricing */}
    <section id="pricing" class="relative py-24 lg:py-36">
      <div class="pointer-events-none absolute inset-0 z-0 border-t border-zinc-200 bg-zinc-50/50"></div>
      <div class="pointer-events-none absolute right-0 bottom-0 z-0 h-[400px] w-[400px] rounded-full bg-brand-accent-1/5 blur-[120px]"></div>

      <div class="content-container relative z-20">
        <div class="mx-auto mb-20 max-w-2xl text-center">
          <h2
            class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.pricing.titleHtml} />
          </h2>
          <p
            class="reveal-element text-lg leading-relaxed font-light text-zinc-600"
          >
            {pageCopy.pricing.subTitle}
          </p>
        </div>

        <div
          class="reveal-grid mx-auto grid max-w-6xl grid-cols-1 items-stretch gap-8 lg:grid-cols-3"
        >
          {/* Starter */}
          <div class="premium-card flex flex-col p-8 h-full">
            <div class="mb-6">
              <h3 class="font-sans mb-4 text-2xl font-[500] text-[#0f0f0f]">
                {pageCopy.pricing.plans.starter.title}
              </h3>
              <p class="text-base leading-relaxed text-[#555555] h-14">
                {pageCopy.pricing.plans.starter.description}
              </p>
            </div>
            <div class="mb-8">
              <div class="flex items-baseline gap-1">
                <div class="text-3xl font-bold text-brand-accent-1">
                  {pageCopy.pricing.plans.starter.price}
                </div>
              </div>
            </div>
            <ul class="mb-8 flex-1 space-y-4 text-sm text-zinc-700">
              {
                pageCopy.pricing.plans.starter.features.map((f) => (
                  <li class="flex items-start gap-3">
                    <svg
                      class="mt-1 h-4 w-4 shrink-0 text-brand-accent-1"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="3"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {f}
                  </li>
                ))
              }
            </ul>
            <a
              href="#audit"
              class="mt-8 w-full inline-flex items-center justify-center gap-x-2 rounded-lg border border-zinc-300 bg-white px-4 py-3 text-center text-sm font-medium text-zinc-700 shadow-xs transition duration-300 hover:bg-brand-accent-1/10 hover:text-brand-accent-1 hover:border-brand-accent-1/40 active:bg-brand-accent-1/20 outline-hidden ring-zinc-500 focus-visible:ring-3"
            >
              Start a pilot
            </a>
          </div>

          {/* Growth */}
          <div class="premium-card group flex flex-col justify-between p-8">
            <div
              class="absolute -top-[14px] left-1/2 -translate-x-1/2 rounded-full bg-brand-accent-1 px-4 py-1 font-mono text-[9px] font-bold tracking-widest text-white uppercase shadow-[0_4px_12px_rgba(var(--brand-accent-1-rgb),0.15)] z-20"
            >
              {pageCopy.pricing.plans.growth.badge}
            </div>
            <div>
              <div class="mb-8">
                <h3 class="font-sans mb-4 text-2xl font-[500] text-[#0f0f0f]">
                  {pageCopy.pricing.plans.growth.title}
                </h3>
                <p class="text-base leading-relaxed text-[#555555] mb-4 h-14">
                  {pageCopy.pricing.plans.growth.description}
                </p>
                <div class="text-3xl font-bold text-brand-accent-1">
                  {pageCopy.pricing.plans.growth.price}
                </div>
              </div>
              <div class="my-6 h-[1px] w-full bg-zinc-200"></div>
              <ul class="mb-10 space-y-4 text-sm text-zinc-700">
                {
                  pageCopy.pricing.plans.growth.features.map((f) => (
                    <li class="flex items-start gap-3">
                      <svg
                        class="mt-1 h-4 w-4 shrink-0 text-brand-accent-1"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="3"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                      {f}
                    </li>
                  ))
                }
              </ul>
            </div>
            <a
              href="#audit"
              class="mt-8 w-full inline-flex items-center justify-center gap-x-2 rounded-lg bg-brand-accent-1 px-4 py-3 text-center text-sm font-medium text-white shadow-[0_4px_12px_rgba(var(--brand-accent-1-rgb),0.25)] transition duration-300 hover:bg-brand-accent-1/90 hover:shadow-[0_6px_20px_rgba(var(--brand-accent-1-rgb),0.35)] outline-hidden ring-zinc-500 focus-visible:ring-3"
            >
              Book a pipeline call
            </a>
          </div>

          {/* Scale */}
          <div class="premium-card flex flex-col p-8 h-full">
            <div class="mb-6">
              <h3 class="font-sans mb-4 text-2xl font-[500] text-[#0f0f0f]">
                {pageCopy.pricing.plans.scale.title}
              </h3>
              <p class="text-base leading-relaxed text-[#555555] h-14">
                {pageCopy.pricing.plans.scale.description}
              </p>
            </div>
            <div class="mb-8">
              <div class="flex items-baseline gap-1">
                <div class="text-3xl font-bold text-brand-accent-1">
                  {pageCopy.pricing.plans.scale.price}
                </div>
              </div>
            </div>
            <ul class="mb-8 flex-1 space-y-4 text-sm text-zinc-700">
              {
                pageCopy.pricing.plans.scale.features.map((f) => (
                  <li class="flex items-start gap-3">
                    <svg
                      class="mt-1 h-4 w-4 shrink-0 text-brand-accent-1"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="3"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    {f}
                  </li>
                ))
              }
            </ul>
            <a
              href="#audit"
              class="mt-8 w-full inline-flex items-center justify-center gap-x-2 rounded-lg border border-zinc-300 bg-white px-4 py-3 text-center text-sm font-medium text-zinc-700 shadow-xs transition duration-300 hover:bg-brand-accent-1/10 hover:text-brand-accent-1 hover:border-brand-accent-1/40 active:bg-brand-accent-1/20 outline-hidden ring-zinc-500 focus-visible:ring-3"
            >
              Talk to us about Scale
            </a>
          </div>
        </div>

        <p class="reveal-element mt-12 text-center text-sm font-medium text-zinc-500 max-w-2xl mx-auto">
          Not sure which tier fits? We'll tell you on the call &mdash; and we won't upsell you into a plan your pipeline isn't ready for.
        </p>
      </div>
    </section>

    {/* Section 7: Final CTA & Contact */}
    <section id="audit" class="relative py-24 lg:py-36">
      <div class="pointer-events-none absolute inset-0 z-0 bg-white"></div>
      <div class="content-container relative z-20">
        <div class="mx-auto mb-12 max-w-3xl text-center">
          <h2
            class="reveal-heading font-display mb-6 text-3xl font-bold tracking-tight text-zinc-950 sm:text-5xl"
          >
            <Fragment set:html={pageCopy.cta.titleHtml} />
          </h2>
          <p
            class="reveal-element text-lg font-light text-zinc-600 whitespace-pre-line"
          >
            {pageCopy.cta.subTitle}
          </p>
        </div>

        {
          /* Contact Form Container (hidden title from contact section for seamless integration) */
        }
        <div class="hide-contact-title">
          <ContactSection />
        </div>
      </div>
    </section>
    </div>
  </div>
</MainLayout>

<style is:global>
  /* Utility to hide Contact Section's native title to avoid redundancy with the CTA */
  .hide-contact-title h1,
  .hide-contact-title p.text-pretty {
    display: none !important;
  }

</style>

<script>
  function initHeroCanvas() {
    const canvas = document.getElementById("c") as HTMLCanvasElement | null;
    const ctx = canvas?.getContext("2d");
    const wrap = document.getElementById("hero-wrap");

    if (!canvas || !ctx || !wrap) return;

    if ((canvas as any)._isAnimating) return;
    (canvas as any)._isAnimating = true;

    let W: number = 0, H: number = 0;
    let t = 0;
    let animationFrameId: number;

    function resize() {
      if (!wrap || !canvas || !ctx) return;
      W = wrap.offsetWidth;
      H = wrap.offsetHeight;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      ctx.scale(dpr, dpr);
    }
    
    const ro = new ResizeObserver(() => resize());
    ro.observe(wrap);
    resize();

    function noise(x: number, y: number, t: number) {
      const v1 =
        Math.sin(x * 0.008 + t * 0.18) * Math.cos(y * 0.009 - t * 0.12);
      const v2 = Math.sin(x * 0.014 - y * 0.007 + t * 0.09);
      const v3 = Math.cos(x * 0.006 + y * 0.011 - t * 0.15) * 0.5;
      const v4 = Math.sin((x + y) * 0.005 + t * 0.07) * 0.3;
      return (v1 + v2 + v3 + v4) / 2.3;
    }

    function getIsoLines(levels: number[]) {
      const step = 6;
      const cols = Math.ceil(W / step) + 1;
      const rows = Math.ceil(H / step) + 1;

      const grid: number[][] = [];
      for (let r = 0; r < rows; r++) {
        grid[r] = [];
        for (let c = 0; c < cols; c++) {
          grid[r][c] = noise(c * step, r * step, t);
        }
      }

      const lines: Record<number, number[][][]> = {};
      levels.forEach((lv) => (lines[lv] = []));

      for (let r = 0; r < rows - 1; r++) {
        for (let c = 0; c < cols - 1; c++) {
          const x0 = c * step,
            y0 = r * step;
          const tl = grid[r][c],
            tr = grid[r][c + 1];
          const bl = grid[r + 1][c],
            br = grid[r + 1][c + 1];

          levels.forEach((lv) => {
            const pts: number[][] = [];

            function interp(
              ax: number,
              ay: number,
              av: number,
              bx: number,
              by: number,
              bv: number,
            ) {
              if (av < lv === bv < lv) return;
              const s = (lv - av) / (bv - av);
              pts.push([ax + (bx - ax) * s, ay + (by - ay) * s]);
            }

            interp(x0, y0, tl, x0 + step, y0, tr);
            interp(x0 + step, y0, tr, x0 + step, y0 + step, br);
            interp(x0, y0 + step, bl, x0 + step, y0 + step, br);
            interp(x0, y0, tl, x0, y0 + step, bl);

            if (pts.length === 2) {
              lines[lv].push(pts);
            }
          });
        }
      }

      return lines;
    }

    function draw() {
      t += 0.012;
      ctx!.clearRect(0, 0, W, H);

      const levelCount = 22;
      const levels: number[] = [];
      for (let i = 0; i < levelCount; i++) {
        levels.push(-1.05 + (i / (levelCount - 1)) * 2.1);
      }

      const isoLines = getIsoLines(levels);

      levels.forEach((lv, idx) => {
        const segs = isoLines[lv];
        if (!segs || !segs.length) return;

        const t_norm = idx / (levelCount - 1);
        const isMid = t_norm > 0.3 && t_norm < 0.7;

        const baseAlpha = isMid ? 0.10 : 0.06;
        const blueBlend = isMid ? 0.4 : 0.1;

        const r = 0;
        const g = 0;
        const b = 0;

        ctx!.strokeStyle = `rgba(${r},${g},${b},${baseAlpha})`;
        ctx!.lineWidth = isMid ? 1.2 : 0.8;
        ctx!.lineCap = "round";
        ctx!.lineJoin = "round";

        segs.forEach(([p1, p2]) => {
          ctx!.beginPath();
          ctx!.moveTo(p1[0], p1[1]);
          ctx!.lineTo(p2[0], p2[1]);
          ctx!.stroke();
        });
      });

      animationFrameId = requestAnimationFrame(draw);
    }

    draw();

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(animationFrameId);
      ro.disconnect();
      if (canvas) (canvas as any)._isAnimating = false;
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initHeroCanvas);
  initHeroCanvas();
</script>
