---
// Destructure the properties from Astro.props
const { id, dataTab, title, first } = Astro.props;

// Define TypeScript interface for the properties
interface Props {
  id: string;
  dataTab: string;
  title: string;
  first?: boolean;
}
// Define constants for styling classes
const BUTTON_CLASS =
  'flex w-full justify-center rounded-xl border border-brand-accent-1/20 bg-[#fafafa]/40 backdrop-blur-sm p-3 outline-hidden transition duration-300 hover:bg-brand-primary/60 hover:border-brand-accent-1/50 hover:ring-2 hover:ring-brand-accent-1/30 focus-visible:ring-3 md:p-5';

const HEADING_CLASS = 'block text-center font-bold';
const INACTIVE_HEADING_CLASS = 'text-brand-text/60';
---

{/* Tab button element */}
<button
  type="button"
  class={`${BUTTON_CLASS} ${first ? 'active bg-brand-primary border-brand-accent-1/60 ring-2 ring-brand-accent-1/40' : ''}`}
  id={id}
  data-target={dataTab}
  role="tab"
>
  {/* Tab text */}
  <span
    class={`${HEADING_CLASS} ${first ? 'text-brand-accent-1' : INACTIVE_HEADING_CLASS}`}
  >
    {title}
  </span>
</button>
