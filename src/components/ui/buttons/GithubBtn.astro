---
import Icon from '@components/ui/icons/Icon.astro';
const { title, url } = Astro.props;

interface Props {
  title?: string;
  url?: string;
}

const baseClasses =
  'group inline-flex w-full items-center justify-center gap-x-[8px] rounded-[8px] px-[24px] py-[12px] text-[14px] font-medium transition-colors duration-150 ease-out outline-hidden active:scale-[0.98]';
const borderClasses = 'border border-transparent';
const bgColorClasses = 'bg-[#0f0f0f] text-white hover:bg-[#2a2a2a]';
const hoverClasses = '';
const fontSizeClasses = '';
const ringClasses = '';
---

<a
  class={`${baseClasses} ${borderClasses} ${bgColorClasses} ${hoverClasses} ${fontSizeClasses} ${ringClasses}`}
  href={url}
  target="_blank"
  rel="noopener noreferrer"
>
  <Icon name="github" />
  {title}
</a>
