---
// Import the necessary dependencies
import PrimaryCTA from "@components/ui/buttons/PrimaryCTA.astro";
import SecondaryCTA from "@components/ui/buttons/SecondaryCTA.astro";
import ReviewComponent from "@components/ui/blocks/ReviewComponent.astro";

// Define props from Astro
const {
  title,
  subTitle,
  primaryBtn,
  primaryBtnURL,
  secondaryBtn,
  secondaryBtnURL,
  withReview,
  avatars,
  starCount,
  rating,
  reviews,
} = Astro.props;

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
  primaryBtn?: string;
  primaryBtnURL?: string;
  secondaryBtn?: string;
  secondaryBtnURL?: string;
  withReview?: boolean;
  avatars?: Array<string>;
  starCount?: number;
  rating?: string;
  reviews?: string;
}
---

{/* Hero section */}
<div class="hero-section-wrapper relative overflow-hidden pb-24 lg:pb-0" id="hero-wrap">
  {/* Backgrounds */}
  <canvas
    id="c"
    class="absolute inset-0 w-full h-full pointer-events-none z-0"
    style="mask-image: linear-gradient(to right, transparent 0%, transparent 45%, black 75%); -webkit-mask-image: linear-gradient(to right, transparent 0%, transparent 45%, black 75%);"
  ></canvas>

  {/* Hero layout: two columns */}
  <section
    class="content-container relative z-10 flex grow flex-col justify-center pt-24 pb-24 px-4 lg:pt-32 lg:pb-32 sm:px-6 lg:px-8 w-full max-w-7xl mx-auto min-h-[92vh]"
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center w-full">
      
      {/* Left Column: Copy */}
      <div class="lg:col-span-6 flex flex-col items-start text-left z-20 lg:pl-6 xl:pl-10">
        <h1
          class="reveal-heading font-display mb-6 text-left text-5xl leading-[1.08] font-bold tracking-[-0.02em] text-zinc-950 sm:text-6xl lg:text-7xl"
        >
          <Fragment set:html={title} />
        </h1>

        {
          subTitle && (
            <p class="reveal-element mb-10 max-w-[600px] text-left text-lg leading-relaxed font-light text-[#444444] sm:text-xl">
              {subTitle}
            </p>
          )
        }

        <div class="reveal-element mt-2 flex flex-col items-start gap-4 w-full">
          <div id="hero-buttons-container" class="flex flex-col sm:flex-row gap-4 w-full">
            {
              primaryBtn && (
                <a
                  href={primaryBtnURL}
                  class="group inline-flex items-center justify-center gap-x-2 rounded-[6px] px-6 py-3.5 text-sm font-medium ring-zinc-500 transition duration-300 focus-visible:ring-3 outline-hidden bg-[#0f0f0f] hover:bg-[#1a1a1a] active:bg-black text-white 2xl:text-base w-full sm:w-fit"
                >
                  {primaryBtn}
                </a>
              )
            }
            {
              secondaryBtn && (
                <a
                  href={secondaryBtnURL}
                  class="inline-flex items-center justify-center gap-x-2 rounded-[6px] border border-zinc-200 bg-white px-6 py-3.5 text-sm font-medium text-zinc-700 shadow-sm transition-all duration-300 hover:bg-zinc-50 hover:text-zinc-900 focus:outline-none focus:ring-2 focus:ring-zinc-500 focus:ring-offset-2 w-full sm:w-fit 2xl:text-base"
                >
                  {secondaryBtn}
                </a>
              )
            }
          </div>
          
          <div class="flex items-center gap-2 text-zinc-500 text-[13px] font-medium mt-1">
            15-min call · no commitment
          </div>
        </div>

        {
          withReview ? (
            <div class="mt-10 sm:mt-12">
              <ReviewComponent
                avatars={avatars}
                starCount={starCount}
                rating={rating}
                reviews={reviews}
              />
            </div>
          ) : (
            ""
          )
        }
      </div>

      {/* Right Column: Premium Animated Dashboard Visual */}
      <div class="lg:col-span-6 relative z-20 w-full h-[380px] sm:h-[420px] lg:h-[480px] hidden sm:flex items-center justify-center perspective-1000 mt-12 lg:mt-0 pr-4 lg:pr-8">
        
        <div class="relative w-full h-full flex items-center justify-center origin-center">
        
          {/* Ambient Glow Behind Dashboard - Monochromatic / Emerald */}
          <div class="absolute inset-0 bg-gradient-to-tr from-zinc-200/40 via-transparent to-emerald-500/5 blur-3xl rounded-full z-0 transform-gpu scale-125"></div>

          {/* Main Dashboard Window - Completely visible within bounds */}
          <div class="dashboard-window relative z-10 w-full max-w-[580px] h-full max-h-[440px] rounded-2xl border border-zinc-200/80 bg-white/70 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.08)] backdrop-blur-2xl overflow-hidden flex flex-col transform-gpu transition-transform duration-700 hover:rotate-y-0 rotate-y-[-4deg] rotate-x-[2deg]">
          
          {/* Header */}
          <div class="h-12 w-full border-b border-zinc-200/60 bg-zinc-50/50 flex items-center px-4 gap-3">
            <div class="flex gap-2">
              <div class="h-3 w-3 rounded-full bg-zinc-300 hover:bg-red-400 transition-colors cursor-pointer"></div>
              <div class="h-3 w-3 rounded-full bg-zinc-300 hover:bg-yellow-400 transition-colors cursor-pointer"></div>
              <div class="h-3 w-3 rounded-full bg-zinc-300 hover:bg-green-400 transition-colors cursor-pointer"></div>
            </div>
            <div class="ml-4 h-5 w-48 rounded-md bg-white border border-zinc-200/60 shadow-sm flex items-center px-2">
              <svg class="w-3 h-3 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
              <div class="ml-2 text-[10px] text-zinc-400 font-medium font-sans">app.sparrow.com/outbound</div>
            </div>
          </div>

          {/* Body */}
          <div class="flex flex-1 p-4 gap-5 bg-zinc-50/30">
            {/* Sidebar */}
            <div class="w-16 sm:w-44 hidden sm:flex flex-col gap-2">
              <div class="h-8 w-full rounded-lg bg-zinc-100 border border-zinc-200/50 mb-2 flex items-center px-3 gap-2">
                <div class="h-4 w-4 rounded-sm bg-zinc-800 shrink-0"></div>
                <div class="text-[11px] font-semibold text-zinc-800">Novapath Systems</div>
              </div>
              <div class="flex items-center gap-3 px-3 py-2 rounded-lg bg-white border border-zinc-200 shadow-sm cursor-pointer relative overflow-hidden">
                 <div class="absolute left-0 top-0 bottom-0 w-1 bg-zinc-800"></div>
                 <svg class="w-4 h-4 text-zinc-800 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>
                 <div class="text-[11px] font-medium text-zinc-800">Command Center</div>
              </div>
              <div class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-zinc-100 transition-colors cursor-pointer">
                 <svg class="w-4 h-4 text-zinc-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                 <div class="text-[11px] font-medium text-zinc-500">Active Campaigns</div>
              </div>
              <div class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-zinc-100 transition-colors cursor-pointer">
                 <svg class="w-4 h-4 text-zinc-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                 <div class="text-[11px] font-medium text-zinc-500">Qualified Leads</div>
              </div>
              
              {/* Sidebar bottom widget */}
              <div class="mt-auto h-24 w-full rounded-xl border border-zinc-200/80 bg-white p-3 flex flex-col justify-end gap-2 shadow-sm relative overflow-hidden group">
                <div class="text-[9px] font-bold text-zinc-400 uppercase tracking-wider">Pipeline Generated</div>
                <div class="h-2 w-full rounded-full bg-zinc-100 overflow-hidden mt-1">
                  <div class="h-full w-[85%] bg-emerald-500 rounded-full progress-bar-1 shadow-sm"></div>
                </div>
                <div class="flex justify-between items-center mt-[-2px]">
                  <div class="text-[9px] text-zinc-500">Q3 Target</div>
                  <div class="text-[10px] font-bold text-zinc-800">85%</div>
                </div>
              </div>
            </div>

            {/* Main Content Area */}
            <div class="flex-1 flex flex-col gap-3 sm:gap-4">
              {/* Top Stats Row */}
              <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                <div class="h-20 sm:h-24 rounded-xl border border-zinc-200/80 bg-white p-3 sm:p-4 flex flex-col justify-between shadow-sm hover:shadow-md transition-shadow">
                  <div class="flex justify-between items-start">
                    <div class="text-[11px] font-semibold text-zinc-500 leading-tight">Meetings Booked</div>
                    <div class="h-6 w-6 rounded-md bg-zinc-50 flex items-center justify-center border border-zinc-100 shrink-0">
                       <svg class="w-3 h-3 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                  </div>
                  <div class="flex items-end gap-2">
                    <div class="text-2xl font-bold text-zinc-900 leading-none">42</div>
                    <div class="text-[10px] font-medium text-emerald-600 bg-emerald-50 px-1.5 py-0.5 rounded-sm mb-0.5">+14%</div>
                  </div>
                </div>
                <div class="h-20 sm:h-24 rounded-xl border border-emerald-500/20 bg-gradient-to-br from-white to-emerald-50/50 p-3 sm:p-4 flex flex-col justify-between shadow-sm relative overflow-hidden hover:shadow-md transition-shadow">
                  <div class="flex justify-between items-start relative z-10">
                    <div class="text-[11px] font-semibold text-emerald-800 leading-tight">Positive Replies</div>
                    <div class="h-6 w-6 rounded-md bg-emerald-100 flex items-center justify-center border border-emerald-200 shrink-0">
                       <svg class="w-3 h-3 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                    </div>
                  </div>
                  <div class="flex items-end gap-2 relative z-10">
                    <div class="text-2xl font-bold text-emerald-900 leading-none">11.2%</div>
                    <div class="text-[10px] font-medium text-emerald-700 bg-emerald-100/50 px-1.5 py-0.5 rounded-sm mb-0.5">Top 1%</div>
                  </div>
                  <div class="absolute -bottom-6 -right-6 w-24 h-24 bg-emerald-500/10 blur-2xl rounded-full"></div>
                </div>
                <div class="h-20 sm:h-24 rounded-xl border border-zinc-200/80 bg-white p-4 flex flex-col justify-between shadow-sm hover:shadow-md transition-shadow hidden sm:flex">
                  <div class="flex justify-between items-start">
                    <div class="text-[11px] font-semibold text-zinc-500 leading-tight">Pipeline Value</div>
                    <div class="h-6 w-6 rounded-md bg-zinc-50 flex items-center justify-center border border-zinc-100 shrink-0">
                       <svg class="w-3 h-3 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                  </div>
                  <div class="flex items-end gap-2">
                    <div class="text-2xl font-bold text-zinc-900 leading-none">$1.2M</div>
                  </div>
                </div>
              </div>

              {/* Chart Area */}
              <div class="flex-1 rounded-xl border border-zinc-200/80 bg-white p-5 flex flex-col gap-4 relative overflow-hidden shadow-sm">
                <div class="flex justify-between items-center">
                  <div class="text-[12px] font-bold text-zinc-800">Opportunities Sourced</div>
                  <div class="flex gap-2">
                    <div class="text-[10px] font-medium text-zinc-500 bg-zinc-50 px-2 py-1 rounded border border-zinc-200 cursor-pointer hover:bg-zinc-100">Weekly</div>
                    <div class="text-[10px] font-medium text-white bg-zinc-800 px-2 py-1 rounded shadow-sm cursor-pointer">Monthly</div>
                  </div>
                </div>
                
                {/* Animated Chart Columns */}
                <div class="flex-1 flex items-end justify-between gap-3 sm:gap-5 pt-4 relative">
                  {/* Grid lines */}
                  <div class="absolute inset-0 flex flex-col justify-between pointer-events-none pb-0">
                     <div class="w-full h-px bg-zinc-100"></div>
                     <div class="w-full h-px bg-zinc-100"></div>
                     <div class="w-full h-px bg-zinc-100"></div>
                     <div class="w-full h-px bg-zinc-200"></div>
                  </div>
                  
                  <div class="w-full bg-zinc-100 rounded-t-sm relative group chart-bar z-10" style="height: 30%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-300 rounded-t-sm"></div>
                  </div>
                  <div class="w-full bg-zinc-100 rounded-t-sm relative group chart-bar z-10" style="height: 45%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-300 rounded-t-sm"></div>
                  </div>
                  <div class="w-full bg-zinc-100 rounded-t-sm relative group chart-bar z-10" style="height: 40%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-300 rounded-t-sm"></div>
                  </div>
                  <div class="w-full bg-zinc-800 rounded-t-sm relative group chart-bar z-10" style="height: 75%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-900 rounded-t-sm"></div>
                    <div class="absolute -top-8 left-1/2 -translate-x-1/2 bg-zinc-900 shadow-lg rounded px-2 py-1 opacity-0 group-hover:opacity-100 transition-opacity z-20 whitespace-nowrap text-[10px] text-white font-bold pointer-events-none">
                      24 Meetings
                      <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-zinc-900 rotate-45"></div>
                    </div>
                  </div>
                  <div class="w-full bg-emerald-500/90 rounded-t-sm relative group chart-bar z-10 shadow-[0_-5px_15px_rgba(16,185,129,0.15)]" style="height: 95%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-emerald-600 rounded-t-sm shadow-[0_0_12px_rgba(16,185,129,0.4)]"></div>
                  </div>
                  <div class="w-full bg-zinc-100 rounded-t-sm relative group chart-bar z-10" style="height: 60%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-300 rounded-t-sm"></div>
                  </div>
                  <div class="w-full bg-zinc-100 rounded-t-sm relative group chart-bar z-10 hidden sm:block" style="height: 80%">
                    <div class="absolute top-0 left-0 right-0 h-1 bg-zinc-300 rounded-t-sm"></div>
                  </div>
                </div>
                {/* X-axis labels */}
                <div class="flex justify-between items-center mt-2 relative z-10 px-1">
