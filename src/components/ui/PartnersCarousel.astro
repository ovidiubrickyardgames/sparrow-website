---
interface Partner {
  name: string;
  logo: string;
}

interface Props {
  partners: Partner[];
}

const { partners } = Astro.props;
---

<div class="partners-carousel-wrapper">
  <div class="trusted-by-container">
    <span class="trusted-by-text">// Trusted by</span>
    <span class="trusted-by-line"></span>
  </div>
  <div class="partners-carousel-container">
    <div class="partners-carousel-track">
      {
        [...partners, ...partners, ...partners].map(partner => (
          <div class="partner-logo-item">
            <img
              src={partner.logo}
              alt={partner.name}
              width="150"
              height="52"
              draggable="false"
              loading="lazy"
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .partners-carousel-wrapper {
    width: 100%;
    position: relative;
    z-index: 20;
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 4rem;
    padding-top: 2rem;
    padding-bottom: 0.5rem;
  }

  .trusted-by-container {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-shrink: 0;
  }

  .trusted-by-text {
    font-family: var(--font-ui, monospace);
    font-size: 1.1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.5);
    white-space: nowrap;
  }

  .trusted-by-line {
    display: block;
    width: 3rem;
    height: 1px;
    background: rgba(255, 255, 255, 0.2);
  }

  .partners-carousel-container {
    overflow: hidden;
    width: 100%;
    /* Gradient mask for smooth fade into transparency on edges */
    mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
  }

  .partners-carousel-track {
    display: flex;
    gap: 8rem;
    width: max-content;
    align-items: center;
    padding: 1rem 0 0.5rem 0;
    animation: scroll 60s linear infinite;
    will-change: transform;
    /* Hardware acceleration to prevent flickering/jumping */
    transform: translateZ(0);
    backface-visibility: hidden;
    perspective: 1000px;
  }

  .partners-carousel-track:hover {
    animation-play-state: paused;
  }

  .partners-carousel-track:hover .partner-logo-item img {
    /* Keep others at base opacity when one is highlighted */
    opacity: 0.7;
  }

  .partner-logo-item {
    flex-shrink: 0;
    width: 200px; /* Fixed width ensures track width is constant */
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .partner-logo-item img {
    height: 52px;
    width: auto;
    opacity: 0.7;
    filter: none;
    transition:
      opacity 0.4s ease,
      filter 0.4s ease,
      transform 0.4s ease;
  }

  .partner-logo-item:hover img {
    opacity: 1 !important;
    filter: none !important;
    transform: scale(1.1);
  }

  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      /* Use calc for maximum precision to prevent sub-pixel jumping */
      transform: translateX(calc(-100% / 3));
    }
  }

  /* Adjustments for mobile */
  @media (max-width: 640px) {
    .partners-carousel-wrapper {
      margin-top: 0;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
      text-align: center;
    }
    .trusted-by-container {
      justify-content: center;
    }
    .trusted-by-line {
      display: none;
    }
    .partners-carousel-track {
      gap: 3.5rem;
      animation-duration: 30s;
    }
    .partner-logo-item {
      width: 120px; /* Smaller fixed width for mobile */
    }
    .partner-logo-item img {
      height: 36px;
    }
  }
</style>
