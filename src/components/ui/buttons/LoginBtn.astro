---
const { title = 'Log in' } = Astro.props;

interface Props {
  title?: string;
}

const baseClasses =
  'group inline-flex items-center justify-center gap-x-[8px] rounded-[8px] px-[24px] py-[12px] text-[14px] font-medium transition-colors duration-150 ease-out outline-hidden active:scale-[0.98] border border-[#0f0f0f] bg-transparent text-[#0f0f0f]';
const hoverClasses = 'hover:bg-[#0f0f0f] hover:text-white';
const darkClasses = '';
const mdClasses = 'md:my-6';
const txtSizeClasses = '';
const userSVG = `<svg
      class="h-4 w-4 shrink-0"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
  >
    <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
    <circle cx="12" cy="7" r="4"></circle>
  </svg>`;
---

<button
  type="button"
  class={`${baseClasses} ${hoverClasses} ${darkClasses} ${mdClasses} ${txtSizeClasses}`}
  data-hs-overlay="#hs-toggle-between-modals-login-modal"
>
  {
    /* About Fragment: https://docs.astro.build/en/basics/astro-syntax/#fragments */
  }

  <Fragment set:html={userSVG} />
  {title}
</button>
