---
// Import the necessary dependencies
import PrimaryCTA from '@components/ui/buttons/PrimaryCTA.astro';
import SecondaryCTA from '@components/ui/buttons/SecondaryCTA.astro';
import ReviewComponent from '@components/ui/blocks/ReviewComponent.astro';


// Define props from Astro
const {
  title,
  subTitle,
  primaryBtn,
  primaryBtnURL,
  secondaryBtn,
  secondaryBtnURL,
  withReview,
  avatars,
  starCount,
  rating,
  reviews,
} = Astro.props;

// Define TypeScript interface for props
interface Props {
  title: string;
  subTitle?: string;
  primaryBtn?: string;
  primaryBtnURL?: string;
  secondaryBtn?: string;
  secondaryBtnURL?: string;
  withReview?: boolean;
  avatars?: Array<string>;
  starCount?: number;
  rating?: string;
  reviews?: string;
}
---

{/* Hero section */}
<div class="hero-section-wrapper relative overflow-hidden pb-24 lg:pb-0">
  {/* Backgrounds */}
  <div class="hero-background-container absolute inset-0" id="wrap">
    <canvas id="c" class="absolute inset-0 w-full h-full"></canvas>
    <div class="hero-gradient-overlay"></div>
  </div>

  {/* Dot grid overlay */}
  <div class="dot-grid pointer-events-none absolute inset-0 z-[2]"></div>



  {/* Hero layout: copy centered */}
  <section
    class="content-container relative z-10 flex grow flex-col items-center justify-center pt-32 pb-24 px-4 sm:pt-40 lg:pt-32 lg:pb-32 sm:px-6 lg:px-8"
  >
    {/* Center-aligned copy */}
    <div
      class="premium-card relative z-20 flex w-full max-w-3xl flex-col items-center rounded-2xl border border-white/10 bg-black/40 p-6 text-center backdrop-blur-xl sm:p-8 lg:p-12"
    >
      {/* Premium eyebrow */}
      <div
        class="mb-3 flex items-center justify-center tracking-[0.12em] text-[11px] uppercase text-[#999] sm:mb-4"
      >
        <span>AI-Powered Pipeline Engine</span>
      </div>

      <h1
        class="text-brand-text dark:text-brand-text/90 block text-center text-3xl font-bold tracking-[-0.02em] text-balance font-display sm:text-5xl lg:text-6xl lg:leading-[1.1]"
      >
        <Fragment set:html={title} />
      </h1>

      {
        subTitle && (
          <p class="text-brand-text/70 dark:text-brand-text/60 mt-6 mx-auto max-w-[520px] text-center text-sm leading-relaxed sm:mt-8 sm:text-lg">
            {subTitle}
          </p>
        )
      }

      <div
        class="mt-10 flex flex-col gap-4 sm:flex-row justify-center"
      >
        {primaryBtn && <a href={primaryBtnURL} class="group inline-flex items-center justify-center gap-x-2 rounded-[6px] px-5 py-3 text-sm font-medium ring-zinc-500 transition duration-300 focus-visible:ring-3 outline-hidden bg-[#0f0f0f] hover:bg-[#1a1a1a] active:bg-black text-white 2xl:text-base">{primaryBtn}</a>}
        {
          secondaryBtn && (
            <SecondaryCTA title={secondaryBtn} url={secondaryBtnURL} />
          )
        }
      </div>

      {
        withReview ? (
          <div class="mt-8 sm:mt-12">
            <ReviewComponent
              avatars={avatars}
              starCount={starCount}
              rating={rating}
              reviews={reviews}
            />
          </div>
        ) : (
          ''
        )
      }
    </div>

    {/* Background — visual motif: Abstract Pipeline */}
    <div class="absolute bottom-0 left-0 right-0 z-[5] pointer-events-none hidden w-full justify-center lg:flex opacity-30">
      <div class="pipeline-graphic relative h-[300px] w-full max-w-[500px]">
        {/* Stages background labels */}
        <div class="absolute -top-6 flex w-full justify-between px-6 text-xs font-bold tracking-widest text-white/30 uppercase">
          <span>Sourced</span>
          <span>Qualified</span>
          <span class="text-brand-accent-1/80">Closed</span>
        </div>
        
        {/* Stages background columns */}
        <div class="absolute inset-0 flex justify-between gap-6">
          <div class="h-full w-1/3 rounded-t-2xl border-t border-l border-r border-white/5 bg-white/[0.02] backdrop-blur-xs"></div>
          <div class="h-full w-1/3 rounded-t-2xl border-t border-l border-r border-white/5 bg-white/[0.02] backdrop-blur-xs"></div>
          <div class="h-full w-1/3 rounded-t-2xl border-t border-l border-r border-brand-accent-1/10 bg-brand-accent-1/5 backdrop-blur-xs"></div>
        </div>
        
        {/* Deal cards */}
        <div class="deal-card card-1 absolute top-12 left-0 h-20 w-[140px] rounded-xl border border-white/10 bg-[#0a0a0a]/80 shadow-xl backdrop-blur-md">
           <div class="h-full w-full p-4 flex flex-col justify-center gap-3">
             <div class="h-2 w-1/3 rounded-full bg-brand-accent-1/40"></div>
             <div class="h-2 w-3/4 rounded-full bg-white/20"></div>
             <div class="h-2 w-1/2 rounded-full bg-white/10"></div>
           </div>
        </div>
        <div class="deal-card card-2 absolute top-40 left-0 h-20 w-[140px] rounded-xl border border-white/10 bg-[#0a0a0a]/80 shadow-xl backdrop-blur-md">
           <div class="h-full w-full p-4 flex flex-col justify-center gap-3">
             <div class="h-2 w-1/4 rounded-full bg-brand-accent-2/40"></div>
             <div class="h-2 w-2/3 rounded-full bg-white/20"></div>
             <div class="h-2 w-1/2 rounded-full bg-white/10"></div>
           </div>
        </div>
        <div class="deal-card card-3 absolute top-68 left-0 h-20 w-[140px] rounded-xl border border-white/10 bg-[#0a0a0a]/80 shadow-xl backdrop-blur-md">
           <div class="h-full w-full p-4 flex flex-col justify-center gap-3">
             <div class="h-2 w-1/2 rounded-full bg-brand-primary/40"></div>
             <div class="h-2 w-4/5 rounded-full bg-white/20"></div>
             <div class="h-2 w-3/4 rounded-full bg-white/10"></div>
           </div>
        </div>
      </div>
    </div>
  </section>

</div>

<style>
  .hero-section-wrapper {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .hero-background-container {
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, transparent 40%, black 100%);
    -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, transparent 40%, black 100%);
  }

  .hero-gradient-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 80% 80% at 50% 50%,
        rgba(18, 18, 18, 0.9) 0%,
        rgba(18, 18, 18, 0.4) 50%,
        transparent 100%
      ),
      linear-gradient(to bottom, rgba(18, 18, 18, 0.6) 0%, transparent 40%);
  }

  /* Dot grid */
  .dot-grid {
    background-image: radial-gradient(
      circle,
      rgba(187, 134, 252, 0.12) 1px,
      transparent 1px
    );
    background-size: 28px 28px;
  }

  /* Animated Pipeline Motif */
  .deal-card {
    animation: moveDeal 7s infinite ease-in-out;
    opacity: 0;
  }
  .card-1 { animation-delay: 0s; }
  .card-2 { animation-delay: 2.5s; }
  .card-3 { animation-delay: 5s; }

  @keyframes moveDeal {
    0% { transform: translateX(-20px) scale(0.95); opacity: 0; }
    10% { transform: translateX(10px) scale(1); opacity: 1; }
    45% { transform: translateX(170px) scale(1.02); opacity: 1; box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3); border-color: rgba(255, 255, 255, 0.15); }
    80% { transform: translateX(330px) scale(1.05); opacity: 1; box-shadow: 0 0 24px 0 rgba(13, 45, 138, 0.3); border-color: rgba(13, 45, 138, 0.4); }
    90% { transform: translateX(350px) scale(1.05); opacity: 0; }
    100% { transform: translateX(350px) scale(0.95); opacity: 0; }
  }

  /* ── Bento stat cards ────────────────────────────── */
  .stat-grid {
    padding: 0 12px 12px;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 10px 8px;
    border: 1px solid rgba(187, 134, 252, 0.14);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.03);
    text-align: center;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: #bb86fc;
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin-top: 4px;
  }
</style>

<script>
  const canvas = document.getElementById('c') as HTMLCanvasElement;
  const ctx = canvas?.getContext('2d');
  const wrap = document.getElementById('wrap');

  if (canvas && ctx && wrap) {
    let W: number, H: number;
    function resize() {
      W = wrap!.offsetWidth;
      H = wrap!.offsetHeight;
      const dpr = window.devicePixelRatio || 1;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      ctx!.scale(dpr, dpr);
    }
    resize();
    window.addEventListener('resize', resize);

    let t = 0;

    function noise(x: number, y: number, t: number) {
      const v1 = Math.sin(x * 0.008 + t * 0.18) * Math.cos(y * 0.009 - t * 0.12);
      const v2 = Math.sin(x * 0.014 - y * 0.007 + t * 0.09);
      const v3 = Math.cos(x * 0.006 + y * 0.011 - t * 0.15) * 0.5;
      const v4 = Math.sin((x + y) * 0.005 + t * 0.07) * 0.3;
      return (v1 + v2 + v3 + v4) / 2.3;
    }

    function getIsoLines(levels: number[]) {
      const step = 6;
      const cols = Math.ceil(W / step) + 1;
      const rows = Math.ceil(H / step) + 1;

      const grid: number[][] = [];
      for (let r = 0; r < rows; r++) {
        grid[r] = [];
        for (let c = 0; c < cols; c++) {
          grid[r][c] = noise(c * step, r * step, t);
        }
      }

      const lines: Record<number, number[][][]> = {};
      levels.forEach(lv => lines[lv] = []);

      for (let r = 0; r < rows - 1; r++) {
        for (let c = 0; c < cols - 1; c++) {
          const x0 = c * step, y0 = r * step;
          const tl = grid[r][c], tr = grid[r][c+1];
          const bl = grid[r+1][c], br = grid[r+1][c+1];

          levels.forEach(lv => {
            const pts: number[][] = [];

            function interp(ax: number, ay: number, av: number, bx: number, by: number, bv: number) {
              if ((av < lv) === (bv < lv)) return;
              const s = (lv - av) / (bv - av);
              pts.push([ax + (bx - ax) * s, ay + (by - ay) * s]);
            }

            interp(x0, y0, tl, x0+step, y0, tr);
            interp(x0+step, y0, tr, x0+step, y0+step, br);
            interp(x0, y0+step, bl, x0+step, y0+step, br);
            interp(x0, y0, tl, x0, y0+step, bl);

            if (pts.length === 2) {
              lines[lv].push(pts);
            }
          });
        }
      }

      return lines;
    }

    function draw() {
      t += 0.012;
      ctx!.clearRect(0, 0, W, H);

      ctx!.clearRect(0, 0, W, H);

      const levelCount = 22;
      const levels: number[] = [];
      for (let i = 0; i < levelCount; i++) {
        levels.push(-1.05 + (i / (levelCount - 1)) * 2.1);
      }

      const isoLines = getIsoLines(levels);

      levels.forEach((lv, idx) => {
        const segs = isoLines[lv];
        if (!segs || !segs.length) return;

        const t_norm = (idx / (levelCount - 1));
        const isMid = t_norm > 0.3 && t_norm < 0.7;

        const baseAlpha = isMid ? 0.08 : 0.05;
        const blueBlend = isMid ? 0.4 : 0.1;

        const r = 0;
        const g = 0;
        const b = 0;

        ctx!.strokeStyle = `rgba(${r},${g},${b},${baseAlpha})`;
        ctx!.lineWidth = isMid ? 1.1 : 0.7;
        ctx!.lineCap = 'round';
        ctx!.lineJoin = 'round';

        segs.forEach(([p1, p2]) => {
          ctx!.beginPath();
          ctx!.moveTo(p1[0], p1[1]);
          ctx!.lineTo(p2[0], p2[1]);
          ctx!.stroke();
        });
      });

      requestAnimationFrame(draw);
    }

    draw();
  }
</script>
